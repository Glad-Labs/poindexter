# ~/.poindexter/bootstrap.toml — Poindexter bootstrap config
#
# This is the ONLY config file Poindexter asks you to write.
# Everything else lives in the app_settings database table once the
# worker connects.
#
# USE THE WIZARD — don't hand-write this. Run:
#
#     poindexter setup
#
# The wizard tests the DB connection, writes the file with safe
# permissions, and seeds the minimum settings. This template is
# here only so you know the format if you ever need to debug.
#
# LOCATION:
#   Linux / macOS:   ~/.poindexter/bootstrap.toml
#   Windows:         %USERPROFILE%\.poindexter\bootstrap.toml
#
# PRIORITY (highest to lowest):
#   1. explicit --db-url CLI argument (tests, automation)
#   2. this file
#   3. DATABASE_URL / LOCAL_DATABASE_URL env vars (Docker, CI)

# Required — PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
database_url = "postgresql://poindexter:your-password@localhost:15432/poindexter_brain"

# Optional — operator-notification channels.
# Used when Poindexter can't start cleanly (missing DB, bad config, etc).
# Leave blank to skip; the system will fall back to ~/.poindexter/alerts.log.
telegram_bot_token = ""
telegram_chat_id = ""
discord_ops_webhook_url = ""
