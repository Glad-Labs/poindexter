{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (spans/sec) by service",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "description": "Server-side request rate per service (Tempo metrics-generator → Prometheus). Excludes client/internal sub-spans so the count matches actual HTTP requests."
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by service",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
          "legendFormat": "p95 {{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Error rate by service (% of requests)",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\",status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum by (service) (rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[5m])), 0.001)",
          "legendFormat": "err% {{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Top spans by call volume (last 5m)",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "topk(20, sum by (service, span_name, status_code) (rate(traces_spanmetrics_calls_total[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "rate" }]
          }
        ]
      },
      "transformations": [{ "id": "merge" }]
    },
    {
      "type": "nodeGraph",
      "title": "Service graph (Tempo metrics-generator)",
      "datasource": { "type": "tempo", "uid": "local-tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "id": 4,
      "targets": [
        {
          "queryType": "serviceMap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Spans ingested (last 5m)",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 18 },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(tempo_distributor_spans_received_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 1 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Spans discarded (last 5m)",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 18 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(tempo_discarded_spans_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Active series (metrics-generator)",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 23 },
      "id": 9,
      "targets": [
        {
          "expr": "sum(tempo_metrics_generator_registry_active_series)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "type": "traces",
      "title": "Recent error traces (TraceQL)",
      "datasource": { "type": "tempo", "uid": "local-tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "id": 5,
      "targets": [
        {
          "query": "{ status = error }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces",
          "limit": 50
        }
      ]
    },
    {
      "type": "traces",
      "title": "Slow requests (>1s, TraceQL)",
      "datasource": { "type": "tempo", "uid": "local-tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 38 },
      "id": 10,
      "targets": [
        {
          "query": "{ kind = server && duration > 1s }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces",
          "limit": 50
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["observability", "tempo", "traces"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Tracing — Tempo",
  "uid": "obs-tempo",
  "version": 2,
  "weekStart": ""
}
