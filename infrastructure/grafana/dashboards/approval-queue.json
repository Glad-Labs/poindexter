          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(quality_score)) AS \"Avg Quality\" FROM content_tasks WHERE status = 'awaiting_approval' AND quality_score IS NOT NULL;",
          "refId": "A"
