# Copy to .env.local and edit. `.env.local` is gitignored by default in
# Next.js projects.

# Where your Poindexter backend is listening. Default is the docker-compose
# service on :8002. Point this at wherever your backend actually runs —
# Tailscale, Cloudflare Tunnel, a Fly.io instance, wherever.
NEXT_PUBLIC_POINDEXTER_API_URL=http://localhost:8002

# Optional: the R2/CDN origin that serves your post images, if you've
# switched the backend to write-through-R2. Not used by the starter's
# default code path (images are fetched at their absolute URLs), but
# here in case you wire it up.
# NEXT_PUBLIC_STATIC_URL=https://your-bucket.r2.dev/static
