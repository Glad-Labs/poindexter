{
  "name": "oversight-hub",
  "version": "3.0.60",
  "private": true,
  "description": "Oversight Hub - React 18 admin interface for monitoring and controlling AI content agents with real-time integration",
  "license": "AGPL-3.0",
  "author": "Matthew M. Gladding (Glad Labs, LLC)",
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation vite",
    "start": "cross-env NODE_OPTIONS=--no-deprecation vite",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "dependencies": {
    "@chatscope/chat-ui-kit-react": "^2.1.1",
    "@chatscope/chat-ui-kit-styles": "^1.4.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@sentry/react": "^8.55.0",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.13.5",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.556.0",
    "markdown": "^0.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-refresh": "^0.14.2",
    "react-router-dom": "^6.30.2",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "vitest": "^2.1.9",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.3",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.14.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "jsonpath": ">=1.1.2",
    "underscore": ">=1.13.7"
  }
}
