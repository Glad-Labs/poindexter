{
  "uid": "cost-control",
  "title": "Cost Control",
  "description": "Spending, tokens",
  "tags": ["glad-labs"],
  "editable": true,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Today",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "text": {
          "valueSize": 28
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(COALESCE(SUM(cost_usd),0)::numeric,4) FROM cost_logs WHERE created_at>=date_trunc('day',NOW())",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "7-Day",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "text": {
          "valueSize": 28
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(COALESCE(SUM(cost_usd),0)::numeric,4) FROM cost_logs WHERE created_at>NOW()-INTERVAL '7 days'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
