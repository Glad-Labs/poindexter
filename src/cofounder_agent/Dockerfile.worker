FROM python:3.12-slim

WORKDIR /app

# Install system deps.
# chromium runtime libs are here because the preview-screenshot QA
# reviewer launches Playwright's bundled chromium from inside the
# container. They're a few hundred MB but cold bytes when the feature
# is off (qa_preview_screenshot_enabled=false by default).
#
# git + gh (GitHub CLI) are installed for the dev_diary topic source
# (services/topic_sources/dev_diary_source.py), which subprocess-calls
# `git log` and `gh pr list` to assemble the daily build-in-public
# context bundle. The host repo is bind-mounted at /app/.git read-only
# (see docker-compose.local.yml worker.volumes) so `git log` has a
# repo to inspect; `gh` reads its auth token from the GH_TOKEN env
# var which the worker injects from app_settings('gh_token') at
# subprocess time. Closes Glad-Labs/poindexter#348.
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl postgresql-client \
    ca-certificates \
    git \
    gnupg \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libatspi2.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libx11-6 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI (gh) from the official cli.github.com apt repo.
# Following the canonical recipe documented at
# https://github.com/cli/cli/blob/trunk/docs/install_linux.md — keyring
# fetched, repo registered, then `apt-get install gh`. Kept as a
# separate RUN layer so the cache invalidates only when this recipe
# changes, not on every base-deps tweak above.
RUN mkdir -p -m 755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Mark /app as a globally-safe git directory.
#
# The dev_diary topic source bind-mounts the host's .git into /app/.git
# (read-only). Since git 2.35.2 (CVE-2022-24765 mitigation), git refuses
# to operate on a repo whose owning UID differs from the current user's
# UID — and inside the container we run as appuser (uid 1001) while
# the host bind-mount preserves the host filesystem UID. Without this
# allow-list entry every `git log` invocation from the dev_diary source
# would fail with "fatal: detected dubious ownership in repository at
# '/app'", and merged_prs would be unavailable for the post.
#
# /etc/gitconfig is the system-wide config that takes effect for ALL
# users in the container (root + appuser), so the value applies before
# we drop privileges below. Read-only mount for /app/.git makes the
# safety relaxation low-risk: nothing in the container can mutate the
# host repo regardless of git's ownership check.
RUN git config --system --add safe.directory /app \
    && git config --system --add safe.directory '*'

# Install poetry
RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir poetry

# Copy dependency files first (cache layer)
COPY pyproject.toml poetry.lock ./

# Install Python deps (no dev deps, no virtualenv)
RUN poetry config virtualenvs.create false && \
    poetry install --no-root --no-dev --no-interaction 2>/dev/null || \
    poetry install --no-root --no-interaction

# Install Playwright's bundled chromium to a shared location so the
# runtime user (if different from the build user) can find it.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright
RUN python -m playwright install chromium && \
    chmod -R a+rX /opt/ms-playwright

# Copy application code
COPY . .

# Non-root user. chmod 0711 on /root so appuser can *traverse* it to reach
# SDXL-generated images under /root/.poindexter/generated-images/ (via the
# compose volume mount) — the directory's own 0777 perms let appuser read
# files; only /root itself blocked traversal until now. Without this,
# featured-image generation silently fell back to Pexels because
# os.path.exists() on the SDXL-returned path raised PermissionError.
RUN addgroup --system --gid 1001 appgroup && \
    adduser --system --uid 1001 --ingroup appgroup --home /home/appuser appuser && \
    chown -R appuser:appgroup /app && \
    chmod 0711 /root
USER appuser

# Health check endpoint
HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8002/api/health')" || exit 1

EXPOSE 8002

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8002"]
