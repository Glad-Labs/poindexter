    {
      "id": 15,
      "title": "Cloud fallback fires (window)",
      "type": "stat",
      "description": "PAID cloud inference calls in the window. Counts cost_logs rows where: (1) provider is not a known-local provider, AND (2) cost_usd > 0, AND (3) if provider=litellm, the model has a cloud-provider prefix (e.g. anthropic/..., openai/...) — bare names (gemma4:31b) and ollama/ prefix are local-Ollama estimates, not real cloud spend. LiteLLM assigns non-zero cost_usd to local models via its pricing table, so cost_usd>0 alone is insufficient; the model-prefix check is the real gate. Any nonzero count = real cloud spend to inspect.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "orange",
                "value": 25
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Cloud fires\" FROM cost_logs WHERE provider NOT IN ('ollama','local','system','electricity','compositor.ffmpeg_local') AND cost_usd > 0 AND NOT (provider = 'litellm' AND (model NOT LIKE '%/%' OR model LIKE 'ollama/%')) AND $__timeFilter(created_at);",
          "refId": "A"
        }
      ]
    },
