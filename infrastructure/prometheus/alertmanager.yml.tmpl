# Alertmanager config TEMPLATE — Phase D4 (GitHub #68) +
# delivery-plane dead-man's switch (Glad-Labs/poindexter#524).
#
# ── WHY THIS IS A `.tmpl` ──────────────────────────────────────────────
# This file is synced to the PUBLIC mirror (Glad-Labs/poindexter). A real
# Telegram `chat_id` is operator-specific and must NEVER be committed, so
# the chat_id is a placeholder here:  ${ALERTMANAGER_TELEGRAM_CHAT_ID}
#
# RenderAlertmanagerConfigJob (services/jobs/render_alertmanager_config.py)
# substitutes the placeholder with `app_settings.telegram_chat_id` (read
# via the SiteConfig DI seam — chat_id is non-secret, so `site_config.get`
# is correct, NOT get_secret) and writes the rendered alertmanager.yml to
# the shared volume Alertmanager reads, then POSTs /-/reload. Same pattern
# as RenderPrometheusRulesJob. On a fresh boot before the first render the
# placeholder is still literal; Alertmanager will fail to parse a chat_id
# of "${...}" and log loudly (per feedback_no_silent_defaults) until the
# render job runs (≤5 min) — the worker-webhook receiver is unaffected.
#
# ── WHY A SECOND, NATIVE-TELEGRAM RECEIVER ─────────────────────────────
# Today EVERY alert funnels through the worker webhook
# (/api/webhooks/alertmanager), which persists to alert_events and relies
# on the brain's Python `alert_dispatch_loop` to actually page. If the
# brain/dispatcher dies, all alerts go dark — exactly the 2026-05-28
# silent-pipeline failure (docs/audits/2026-05-29-observability-doctor-
# audit.md Finding #1).
#
# The `dead-mans-switch-telegram` receiver below uses Alertmanager's
# NATIVE telegram_configs — it talks to the Telegram Bot API directly from
# the Alertmanager process. The dead-man's switch alert is delivered on
# THREE independent axes from the normal plane:
#   - own process: Alertmanager, not the brain daemon
#   - own token:   /etc/alertmanager/telegram-token (bot token), separate
#                  from the worker webhook bearer token
#   - own route:   matched and terminated (`continue: false`) BEFORE the
#                  default worker-webhook route
# So even if the brain, the worker, and the Python dispatch loop are all
# down, this one alert still reaches the operator.
#
# Everything that is NOT the dead-man's switch still falls through to the
# `poindexter-webhook` receiver exactly as before.

global:
  resolve_timeout: 5m

route:
  receiver: poindexter-webhook
  group_by: ["alertname", "category"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    # Dead-man's switch — independent delivery path (#524). Matched
    # FIRST and terminated so it never touches the worker webhook /
    # Python dispatch loop it exists to back up. Tighter repeat_interval
    # than the default 4h: if the brain is down we want to keep nudging.
    - matchers:
        - delivery_plane = "dead_mans_switch"
      receiver: dead-mans-switch-telegram
      continue: false
      group_wait: 0s
      group_interval: 5m
      repeat_interval: 30m

receivers:
  - name: poindexter-webhook
    webhook_configs:
      - url: http://worker:8002/api/webhooks/alertmanager
        send_resolved: true
        # Bearer token auth — the worker rejects any POST without the
        # matching Authorization header. Token lives in app_settings
        # as `alertmanager_webhook_token` (is_secret=true, encrypted
        # at rest). Mounted at /etc/alertmanager/webhook-token so a
        # single file rotation swaps the value without a config reload.
        http_config:
          bearer_token_file: /etc/alertmanager/webhook-token

  # #524 — native Telegram delivery for the dead-man's switch ONLY.
  # bot_token_file mirrors the webhook-token file pattern: the brain's
  # prometheus_secret_writer decrypts app_settings.telegram_bot_token and
  # writes it to the shared prometheus secrets dir
  # (alertmanager-telegram-token) every cycle. chat_id is rendered in from
  # app_settings.telegram_chat_id by RenderAlertmanagerConfigJob (non-secret
  # → safe to render, never the committed value).
  - name: dead-mans-switch-telegram
    telegram_configs:
      - bot_token_file: /etc/alertmanager/secrets/alertmanager-telegram-token
        chat_id: ${ALERTMANAGER_TELEGRAM_CHAT_ID}
        parse_mode: HTML
        send_resolved: true
        message: |
          <b>🚨 DEAD-MAN'S SWITCH: {{ .CommonLabels.alertname }}</b>
          {{ range .Alerts }}{{ .Annotations.summary }}
          {{ .Annotations.description }}{{ end }}

# Inhibition rules — suppress lower-severity alerts when a related
# higher-severity one is firing.
inhibit_rules:
  - source_matchers:
      - severity = "critical"
    target_matchers:
      - severity = "warning"
    equal: ["alertname", "instance"]
