      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3600
              },
              {
                "color": "orange",
                "value": 86400
              },
              {
                "color": "red",
                "value": 604800
              }
            ]
          },
          "unit": "s",
