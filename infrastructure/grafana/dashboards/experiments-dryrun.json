      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH daily AS (\n  SELECT\n    date_trunc('day', co.created_at) AS day,\n    ev.id                            AS variant_id,\n    ev.label                         AS variant_label,\n    e.key                            AS experiment_key,\n    COUNT(*)                                                       AS runs,\n    COUNT(*) FILTER (WHERE pem.approver IS NOT NULL)               AS approved\n  FROM capability_outcomes co\n  JOIN experiment_variants ev ON ev.id = co.variant_id\n  JOIN experiments e          ON e.id = ev.experiment_id\n  LEFT JOIN published_post_edit_metrics pem ON pem.task_id = co.task_id\n  WHERE co.variant_id IS NOT NULL\n    AND e.status = 'active'\n    AND co.created_at > NOW() - INTERVAL '30 days'\n  GROUP BY 1, 2, 3, 4\n)\nSELECT\n  day                                                          AS time,\n  experiment_key || ' / ' || variant_label                     AS metric,\n  ROUND(\n    (SUM(approved) OVER w)::numeric\n    / NULLIF((SUM(runs) OVER w)::numeric, 0) * 100, 1\n  )::float                                                      AS value\nFROM daily\nWINDOW w AS (\n  PARTITION BY variant_id\n  ORDER BY day\n  RANGE BETWEEN INTERVAL '6 days' PRECEDING AND CURRENT ROW\n)\nORDER BY time, metric;",
          "refId": "A"
        }
      ]
    }
