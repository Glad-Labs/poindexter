{
  "uid": "quality-metrics",
  "title": "Quality Metrics",
  "description": "Content quality scores -- trends, distribution, and pass rates",
  "tags": ["glad-labs", "quality", "content"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "refresh": "15m",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Average Quality Score (Daily)",
      "type": "timeseries",
      "gridPos": { "h": 12, "w": 16, "x": 0, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "semi-dark-blue", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Quality Score",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 6,
            "showPoints": "always",
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(255, 0, 0, 0.05)", "value": 0 },
              { "color": "transparent", "value": 7 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 10,
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT date_trunc('day', created_at) as time, AVG(quality_score) as avg_quality FROM content_tasks WHERE quality_score IS NOT NULL AND $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "title": "Quality Pass Rate (7d)",
      "type": "gauge",
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE quality_score >= 7.0) * 100.0 / NULLIF(COUNT(*), 0), 1) as pass_rate FROM content_tasks WHERE quality_score IS NOT NULL AND created_at > NOW() - INTERVAL '7 days'",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "title": "Quality Score Distribution (30d)",
      "type": "histogram",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 4 },
              { "color": "yellow", "value": 6 },
              { "color": "green", "value": 7 },
              { "color": "dark-green", "value": 9 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 10
        },
        "overrides": []
      },
      "options": {
        "bucketSize": 1,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT quality_score FROM content_tasks WHERE quality_score IS NOT NULL AND created_at > NOW() - INTERVAL '30 days'",
          "format": "table",
          "editorMode": "code"
        }
      ]
    }
  ]
}
