    {
      "type": "stat",
      "id": 12,
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 29
      },
      "title": "Dry-Run Q",
      "datasource": {
        "type": "postgres",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(quality_score)::numeric, 1)::float AS value FROM pipeline_tasks_view WHERE status = 'dry_run' AND quality_score IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "blue",
                "value": 80
              }
            ]
          },
          "unit": "short",
          "max": 100,
          "min": 0
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "id": 13,
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 29
      },
      "title": "Dry-Run mode",
      "datasource": {
        "type": "postgres",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN value IN ('true','1','yes','on') THEN 'ON' ELSE 'off' END AS value FROM app_settings WHERE key = 'pipeline_dry_run_mode'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "ON": {
                  "color": "purple",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "off": {
                  "color": "blue",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/.*/",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
      "id": 14,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "title": "Dry-Run Generation Rate",
      "datasource": {
        "type": "postgres",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('minute', updated_at) AS time, COUNT(*)::int AS dry_run FROM pipeline_tasks WHERE status = 'dry_run' AND $__timeFilter(updated_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "showLegend": false,
          "displayMode": "list",
