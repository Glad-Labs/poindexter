    {
      "id": 2,
      "type": "stat",
      "title": "Gaming",
      "description": "Pipeline pauses automatically when external GPU workload (gaming) is detected",
      "datasource": {
        "type": "prometheus",
        "uid": "local-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "Clear",
                  "color": "blue"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "1": {
                  "text": "Gaming",
                  "color": "orange"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "local-prometheus"
          },
          "expr": "poindexter_gpu_gaming_detected",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "GPU Utilization & Temperature",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "local-prometheus"
