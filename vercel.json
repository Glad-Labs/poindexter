{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web/public-site && npm run build",
  "devCommand": "cd web/public-site && npm run dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "cleanUrls": true,
  "trailingSlash": false,
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- web/public-site/ package.json package-lock.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "gladlabs.io" }],
      "destination": "https://www.gladlabs.io/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "0"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
