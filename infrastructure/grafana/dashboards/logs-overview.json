      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "local-loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({compose_project=~\".+\"} |~ \"(?i)error|exception|traceback|critical\" [24h]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Errors (24h)",
      "type": "stat"
