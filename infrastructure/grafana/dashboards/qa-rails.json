      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH expanded AS (\n  SELECT r.value->>'reviewer' AS reviewer,\n         (r.value->>'score')::float AS reviewer_score\n  FROM audit_log al\n  CROSS JOIN LATERAL jsonb_array_elements(al.details->'reviews') AS r(value)\n  WHERE al.event_type = 'qa_pass_completed'\n    AND al.created_at > NOW() - INTERVAL '24 hours'\n)\nSELECT reviewer AS metric,\n       ROUND(AVG(reviewer_score)::numeric, 1)::float AS value\nFROM expanded\nGROUP BY reviewer\nHAVING COUNT(*) >= 5\nORDER BY value DESC;",
          "refId": "A"
        }
      ],
      "title": "Avg Score by Reviewer (24h)",
      "type": "bargauge"
    },
