{
  "uid": "phone-command-center",
  "title": "Phone Command Center",
  "description": "Mobile-optimized single-column dashboard for monitoring Glad Labs on the go",
  "tags": ["glad-labs", "mobile", "command-center"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m"],
    "time_options": ["1h", "6h", "12h", "24h", "7d"]
  },
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 1,
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Published Posts",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Posts\" FROM content_tasks WHERE status = 'published'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Today's Tasks",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FILTER (WHERE status = 'completed') AS \"Done\", COUNT(*) FILTER (WHERE status = 'failed') AS \"Fail\", COUNT(*) FILTER (WHERE status NOT IN ('completed', 'failed')) AS \"Pend\" FROM content_tasks WHERE created_at >= CURRENT_DATE",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Fail"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pend"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "yellow",
                      "value": null
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "GPU Temp",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT temperature || ' C' as \"GPU Temp\" FROM gpu_metrics ORDER BY timestamp DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Errors (1h)",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Errors\" FROM audit_log WHERE \"timestamp\" >= NOW() - INTERVAL '1 hour' AND severity = 'error'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      }
    },
    {
      "id": 10,
      "title": "Recent Tasks",
      "type": "table",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "targets": [
        {
          "rawSql": "SELECT LEFT(task_type, 15) AS \"Type\", status AS \"Status\", COALESCE(ROUND(quality_score::numeric, 1)::text, '-') AS \"Q\", to_char(created_at, 'HH24:MI') AS \"Time\" FROM content_tasks ORDER BY created_at DESC LIMIT 5",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "completed": {
                        "text": "completed",
                        "color": "green"
                      },
                      "failed": {
                        "text": "failed",
                        "color": "red"
                      },
                      "pending": {
                        "text": "pending",
                        "color": "yellow"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 20,
      "title": "Today's Spend",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(ROUND(SUM(cost_usd)::numeric, 4), 0) AS \"Today $\" FROM cost_logs WHERE created_at >= CURRENT_DATE",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 4
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      }
    },
    {
      "id": 21,
      "title": "7-Day Spend",
      "type": "timeseries",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', created_at) AS time, SUM(cost_usd) AS \"Cost\" FROM cost_logs WHERE created_at >= NOW() - INTERVAL '7 days' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 4,
            "showPoints": "always",
            "spanNulls": true,
            "axisBorderShow": false
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 30,
      "title": "DB Connections",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Conns\" FROM pg_stat_activity WHERE datname = current_database()",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      }
    },
    {
      "id": 31,
      "title": "Ollama (Last Activity)",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN MAX(timestamp) >= NOW() - INTERVAL '10 minutes' THEN 'ACTIVE' WHEN MAX(timestamp) >= NOW() - INTERVAL '1 hour' THEN 'IDLE' ELSE 'STALE' END AS \"Status\" FROM gpu_metrics WHERE utilization > 10",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "ACTIVE": {
                  "text": "ACTIVE",
                  "color": "green"
                },
                "IDLE": {
                  "text": "IDLE",
                  "color": "yellow"
                },
                "STALE": {
                  "text": "STALE",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "textMode": "auto",
        "graphMode": "none"
      }
    },
    {
      "id": 32,
      "title": "Embeddings",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Total\" FROM embeddings",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      }
    },
    {
      "id": 40,
      "title": "Recent Errors",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "targets": [
        {
          "rawSql": "SELECT to_char(\"timestamp\", 'HH24:MI') AS \"Time\", source AS \"Source\", LEFT(details::text, 80) AS \"Details\" FROM audit_log WHERE severity = 'error' ORDER BY \"timestamp\" DESC LIMIT 3",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false
          },
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    }
  ]
}
