FROM python:3.13-slim

WORKDIR /app

# Install system deps.
# chromium runtime libs are here because the preview-screenshot QA
# reviewer launches Playwright's bundled chromium from inside the
# container. They're a few hundred MB but cold bytes when the feature
# is off (qa_preview_screenshot_enabled=false by default).
#
# git + gh (GitHub CLI) are installed for the dev_diary topic source
# (services/topic_sources/dev_diary_source.py), which subprocess-calls
# `git log` and `gh pr list` to assemble the daily build-in-public
# context bundle. The host repo is bind-mounted at /app/.git read-only
# (see docker-compose.local.yml worker.volumes) so `git log` has a
# repo to inspect; `gh` reads its auth token from the GH_TOKEN env
# var which the worker injects from app_settings('gh_token') at
# subprocess time. Closes Glad-Labs/poindexter#348.
#
# ffmpeg supplies the system binary the media compositor shells out to
# (plugin.media_compositor.ffmpeg_local.binary_path, default `ffmpeg`) when the
# Stage-2 media_pipeline renders podcast / long-form / short-form video. Without
# it the render_long_video / render_short_video atoms fail at the compositing
# step and Stage-2 silently produces no video assets. See Glad-Labs/poindexter#689.
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl postgresql-client \
    ffmpeg \
    ca-certificates \
    git \
    gnupg \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libatspi2.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libx11-6 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI (gh) from the official cli.github.com apt repo.
# Following the canonical recipe documented at
# https://github.com/cli/cli/blob/trunk/docs/install_linux.md — keyring
# fetched, repo registered, then `apt-get install gh`. Kept as a
# separate RUN layer so the cache invalidates only when this recipe
# changes, not on every base-deps tweak above.
RUN mkdir -p -m 755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Mark /app as a globally-safe git directory.
#
# The dev_diary topic source bind-mounts the host's .git into /app/.git
# (read-only). Since git 2.35.2 (CVE-2022-24765 mitigation), git refuses
# to operate on a repo whose owning UID differs from the current user's
# UID — and inside the container we run as appuser (uid 1001) while
# the host bind-mount preserves the host filesystem UID. Without this
# allow-list entry every `git log` invocation from the dev_diary source
# would fail with "fatal: detected dubious ownership in repository at
# '/app'", and merged_prs would be unavailable for the post.
#
# /etc/gitconfig is the system-wide config that takes effect for ALL
# users in the container (root + appuser), so the value applies before
# we drop privileges below. Read-only mount for /app/.git makes the
# safety relaxation low-risk: nothing in the container can mutate the
# host repo regardless of git's ownership check.
RUN git config --system --add safe.directory /app \
    && git config --system --add safe.directory '*'

# Install poetry (2.2.1 pinned — matches brain/Dockerfile and the cofounder image
# for reproducibility; unpinned `pip install poetry` was resolving to 2.x anyway
# but a future pip release could pull a 3.x breaking version unexpectedly).
RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir 'poetry==2.2.1'

# Copy dependency files first (cache layer)
COPY pyproject.toml poetry.lock ./

# Install Python deps (no dev deps, no virtualenv).
#
# --extras profiling pulls in ``pyroscope-io`` so services/profiling.py
# can ship CPU profiles to the Pyroscope server (Glad-Labs/poindexter#406).
# Without the extra the import in profiling.py silently fails and
# Pyroscope only ever sees its own self-profile — exactly the gap #406
# closes. Outside this Linux container the extra is gated by the
# ``sys_platform != 'win32'`` marker on the dependency, so Matt's
# Windows host `poetry install --extras profiling` still skips cleanly.
#
# --extras youtube pulls in google-auth / google-auth-oauthlib /
# google-api-python-client so services/publish_adapters/youtube.py can
# resumable-upload MP4s. The host CLI (`poindexter integrations youtube
# setup`) installs these on Matt's machine, but the worker container —
# which actually runs the backfill_videos publish dispatch — needs them
# baked in or the publishing.youtube handler ImportErrors at dispatch.
RUN poetry config virtualenvs.create false && \
    poetry install --no-root --only main --no-interaction --extras "profiling youtube rerank"

# Fail-fast verification — confirm the pyroscope-io wheel actually
# landed in the image. If `[profiling]` was silently dropped (resolver
# fallback, marker mismatch, partial layer cache), the worker would
# boot, log "[PYROSCOPE] pyroscope-io not installed", and we'd notice
# only by spotting the absence of `poindexter-worker` in the
# Pyroscope UI — too easy to miss. Failing the build instead surfaces
# the regression at CI time.
#
# Asserting on ``configure`` (the API surface profiling.py calls)
# rather than ``__version__`` (which pyroscope-io 0.8.x doesn't expose)
# — the contract we need to verify is that the symbol exists, not the
# version number. Closes Glad-Labs/poindexter#406.
RUN python -c "import pyroscope; assert hasattr(pyroscope, 'configure'), 'pyroscope wheel missing configure()'; print('[BUILD] pyroscope-io OK — configure available')"

# Fail-fast verification — confirm the YouTube upload stack landed. If
# `[youtube]` was silently dropped, publishing.youtube would ImportError
# only when the backfill_videos job tries to dispatch an upload — a
# runtime failure on the publish path. Assert at build time instead.
RUN python -c "import googleapiclient.discovery, google_auth_oauthlib.flow, google.oauth2.credentials; print('[BUILD] youtube extra OK — google api client + oauth available')"

# Fail-fast verification — confirm the rerank stack landed AND that torch is the
# CPU build. sentence-transformers is an opt-in `rerank` extra (it was a main dep
# until the 2026-06-23 CI torch-trim); if `[rerank]` is ever dropped from the
# --extras line above, the LlamaIndex cross-encoder reranker (services/rag_engine.py)
# would ImportError at first use and silently degrade to passthrough. The
# torch.version.cuda assertion guards the 2026-06-23 CPU-trim: this image has no
# GPU passthrough and no diffusers, so it must carry the ~2 GB-smaller CPU wheel,
# not cu128. A future re-lock that re-pulls a CUDA torch reddens the build here
# instead of silently re-bloating the image. cu128 lives in scripts/Dockerfile.image-gen.
RUN python -c "import sentence_transformers, torch; assert torch.version.cuda is None, f'expected CPU torch, got CUDA {torch.version.cuda}'; print('[BUILD] rerank extra OK — sentence_transformers + CPU torch', torch.__version__)"

# Install Playwright's bundled chromium to a shared location so the
# runtime user (if different from the build user) can find it.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright
RUN python -m playwright install chromium && \
    chmod -R a+rX /opt/ms-playwright

# Copy application code
COPY . .

# Non-root user. chmod 0711 on /root so appuser can *traverse* it to reach
# image-gen-generated images under /root/.poindexter/generated-images/ (via the
# compose volume mount) — the directory's own 0777 perms let appuser read
# files; only /root itself blocked traversal until now. Without this,
# featured-image generation silently fell back to Pexels because
# os.path.exists() on the image-gen-returned path raised PermissionError.
RUN addgroup --system --gid 1001 appgroup && \
    adduser --system --uid 1001 --ingroup appgroup --home /home/appuser appuser && \
    chown -R appuser:appgroup /app && \
    chmod 0711 /root
USER appuser

# Health check endpoint
HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8002/api/health')" || exit 1

EXPOSE 8002

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8002"]
