          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(input_tokens+output_tokens) FROM cost_logs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "By Provider",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT provider as metric, ROUND(SUM(cost_usd)::numeric,4) as value FROM cost_logs GROUP BY 1 ORDER BY 2 DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "By Phase",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(phase,'?') as metric, ROUND(SUM(cost_usd)::numeric,4) as value FROM cost_logs GROUP BY 1 ORDER BY 2 DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Daily",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day',created_at)::date as day, provider, COUNT(*) as calls, ROUND(SUM(cost_usd)::numeric,6) as cost, SUM(input_tokens+output_tokens) as tokens FROM cost_logs GROUP BY 1,2 ORDER BY 1 DESC LIMIT 20",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "By Model",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT model, COUNT(*) as calls, ROUND(SUM(cost_usd)::numeric,6) as cost, SUM(input_tokens) as in_tok, SUM(output_tokens) as out_tok FROM cost_logs GROUP BY 1 ORDER BY 3 DESC",
          "refId": "A"
        }
      ]
    }
  ]
}
