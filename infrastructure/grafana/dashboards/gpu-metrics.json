{
  "uid": "gpu-metrics",
  "title": "GPU Metrics",
  "description": "NVIDIA GPU monitoring — utilization, temperature, power, VRAM, clocks, fan speed",
  "tags": ["glad-labs", "infrastructure", "gpu"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "30m", "1h", "3h", "6h", "12h", "24h"]
  },
  "refresh": "15s",
  "schemaVersion": 39,
  "version": 1,
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 100,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## GPU — RTX 5090"
      }
    },
    {
      "id": 1,
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 2 },
      "datasource": {
        "type": "prometheus",
        "uid": "dfht40ysx6o00f"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "dfht40ysx6o00f"
          },
          "expr": "nvidia_gpu_utilization_percent{gpu=\"0\"}",
          "legendFormat": "GPU Util %"
        }
      ]
