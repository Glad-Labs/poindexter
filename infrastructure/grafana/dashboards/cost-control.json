{
  "uid": "cost-control",
  "title": "Cost Control",
  "description": "LLM spend tracking -- daily costs, provider breakdown, budget monitoring",
  "tags": ["glad-labs", "costs", "budget"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "refresh": "15m",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Daily Spend",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "USD",
            "drawStyle": "bars",
            "fillOpacity": 70,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 4 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "currencyUSD",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT date_trunc('day', created_at) as time, SUM(cost_usd) as daily_cost FROM cost_logs WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "title": "Budget Gauge (Daily $5 Limit)",
      "type": "gauge",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2.5 },
              { "color": "orange", "value": 4 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "currencyUSD",
          "min": 0,
          "max": 5
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT SUM(cost_usd) as today_spend FROM cost_logs WHERE created_at > date_trunc('day', NOW())",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cost by Provider (30d)",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "anthropic" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "super-light-orange", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "openai" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "semi-dark-green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "google" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "blue", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ollama" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "purple", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT provider, SUM(cost_usd) as total FROM cost_logs WHERE created_at > NOW() - INTERVAL '30 days' GROUP BY provider",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cost by Phase (30d)",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "USD",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "unit": "currencyUSD",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT phase, SUM(cost_usd) as total FROM cost_logs WHERE created_at > NOW() - INTERVAL '30 days' GROUP BY phase ORDER BY total DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cost per Post",
      "type": "stat",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT ROUND(AVG(task_cost), 4) as avg_cost_per_post FROM (SELECT task_id, SUM(cost_usd) as task_cost FROM cost_logs GROUP BY task_id) sub",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token Usage by Model (7d)",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Tokens",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT model, SUM(total_tokens) as tokens FROM cost_logs WHERE created_at > NOW() - INTERVAL '7 days' GROUP BY model ORDER BY tokens DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    }
  ]
}
