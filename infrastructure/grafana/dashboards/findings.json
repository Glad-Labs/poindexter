          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT f.kind AS \"Kind\", f.cnt AS \"Count\", COALESCE(p.value, 'route (unconfigured)') AS \"Delivery Policy\" FROM (SELECT details->>'kind' AS kind, COUNT(*)::int AS cnt FROM audit_log WHERE event_type = 'finding' AND $__timeFilter(timestamp) GROUP BY 1) f LEFT JOIN app_settings p ON p.key = 'findings.' || f.kind || '.delivery' ORDER BY f.cnt DESC;",
          "refId": "A"
