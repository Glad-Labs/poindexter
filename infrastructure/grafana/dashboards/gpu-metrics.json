{
  "uid": "gpu-metrics",
  "title": "GPU Metrics",
  "description": "NVIDIA GPU monitoring - utilization, temperature, power, VRAM, clocks, fan speed",
  "tags": ["glad-labs", "infrastructure", "gpu"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "30m", "1h", "3h", "6h", "12h", "24h"]
  },
  "refresh": "15s",
  "schemaVersion": 39,
  "version": 1,
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Util %",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]},
          "min": 0, "max": 100, "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": { "titleSize": 10, "valueSize": 24 }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "table", "rawQuery": true,
        "rawSql": "SELECT utilization FROM gpu_metrics ORDER BY timestamp DESC LIMIT 1"
      }]
    },
    {
      "id": 2,
      "title": "Temp",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]},
          "min": 0, "max": 100, "unit": "celsius"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": { "titleSize": 10, "valueSize": 24 }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "table", "rawQuery": true,
        "rawSql": "SELECT temperature FROM gpu_metrics ORDER BY timestamp DESC LIMIT 1"
      }]
    },
    {
      "id": 3,
      "title": "Power",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 300 },
            { "color": "red", "value": 500 }
          ]},
          "min": 0, "max": 600, "unit": "watt"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": { "titleSize": 10, "valueSize": 24 }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "table", "rawQuery": true,
        "rawSql": "SELECT power_draw FROM gpu_metrics ORDER BY timestamp DESC LIMIT 1"
      }]
    },
    {
      "id": 4,
      "title": "VRAM %",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]},
          "min": 0, "max": 100, "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": { "titleSize": 10, "valueSize": 24 }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "table", "rawQuery": true,
        "rawSql": "SELECT ROUND((memory_used::numeric / NULLIF(memory_total, 0)) * 100, 1) AS vram_pct FROM gpu_metrics ORDER BY timestamp DESC LIMIT 1"
      }]
    },
    {
      "id": 5,
      "title": "Fan",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ]},
          "min": 0, "max": 100, "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": { "titleSize": 10, "valueSize": 24 }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "table", "rawQuery": true,
        "rawSql": "SELECT fan_speed FROM gpu_metrics ORDER BY timestamp DESC LIMIT 1"
      }]
    },
    {
      "id": 6,
      "title": "Clock",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2000 },
            { "color": "red", "value": 2500 }
          ]},
          "min": 0, "max": 3000, "unit": "rotmhz"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": { "titleSize": 10, "valueSize": 24 }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "table", "rawQuery": true,
        "rawSql": "SELECT clock_graphics FROM gpu_metrics ORDER BY timestamp DESC LIMIT 1"
      }]
    },
    {
      "id": 10,
      "title": "Util + Temp",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 3 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth",
            "fillOpacity": 10, "pointSize": 1, "showPoints": "never",
            "lineWidth": 1, "spanNulls": false,
            "axisBorderShow": false, "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" }
          },
          "min": 0, "max": 100
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "utilization" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.axisPlacement", "value": "left" }
            ]},
          { "matcher": { "id": "byName", "options": "temperature" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]}
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "time_series", "rawQuery": true,
        "rawSql": "SELECT timestamp AS time, utilization, temperature FROM gpu_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
      }]
    },
    {
      "id": 11,
      "title": "Power + VRAM",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 3 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth",
            "fillOpacity": 10, "pointSize": 1, "showPoints": "never",
            "lineWidth": 1, "spanNulls": false,
            "axisBorderShow": false, "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" }
          },
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "power_draw" },
            "properties": [
              { "id": "unit", "value": "watt" },
              { "id": "custom.axisPlacement", "value": "left" }
            ]},
          { "matcher": { "id": "byName", "options": "memory_used" },
            "properties": [
              { "id": "unit", "value": "decmbytes" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]}
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "time_series", "rawQuery": true,
        "rawSql": "SELECT timestamp AS time, power_draw, memory_used FROM gpu_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
      }]
    },
    {
      "id": 12,
      "title": "Fan + Clocks",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth",
            "fillOpacity": 5, "pointSize": 1, "showPoints": "never",
            "lineWidth": 1, "spanNulls": false,
            "axisBorderShow": false, "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" }
          },
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "fan_speed" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "max", "value": 100 }
            ]},
          { "matcher": { "id": "byName", "options": "clock_graphics" },
            "properties": [
              { "id": "unit", "value": "rotmhz" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]},
          { "matcher": { "id": "byName", "options": "clock_memory" },
            "properties": [
              { "id": "unit", "value": "rotmhz" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]}
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "time_series", "rawQuery": true,
        "rawSql": "SELECT timestamp AS time, fan_speed, clock_graphics, clock_memory FROM gpu_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
      }]
    },
    {
      "id": 13,
      "title": "Memory Detail",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth",
            "fillOpacity": 15, "pointSize": 1, "showPoints": "never",
            "lineWidth": 1, "spanNulls": false,
            "axisBorderShow": false, "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" }
          },
          "unit": "decmbytes", "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "local-brain-db" },
        "format": "time_series", "rawQuery": true,
        "rawSql": "SELECT timestamp AS time, memory_used FROM gpu_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
      }]
    }
  ]
}