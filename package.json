{
  "name": "poindexter-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Poindexter — AI content pipeline with autonomous agents. Built by Glad Labs LLC.",
  "license": "AGPL-3.0-or-later",
  "author": "Matthew M. Gladding (Glad Labs, LLC)",
  "workspaces": [
    "packages/brand",
    "web/public-site",
    "web/storefront"
  ],
  "scripts": {
    "//": "=== CORE WORKFLOWS ===",
    "dev": "npm run setup:dev && npm run link:env && concurrently \"npm run dev:cofounder\" \"npm run dev:frontend\"",
    "start": "npm run dev",
    "dev:all": "npm run dev",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:web": "npm run test",
    "test:py": "npm run test:python",
    "test:py:smoke": "npm run test:python:smoke",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" \"!**/package-lock.json\" \"!**/node_modules/**\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\" \"!**/package-lock.json\" \"!**/node_modules/**\"",
    "ci": "npm run format:check && npm run lint && npm run test:ci",
    "check": "npm run ci",
    "scripts:list": "node -e \"const scripts=require('./package.json').scripts;console.log(Object.keys(scripts).filter((k)=>!k.startsWith('//')).sort().join('\\n'))\"",
    "scripts:help": "node -e \"console.log(['Core: dev/start, build, test, test:web, test:py, lint, format:check, ci/check','Frontend dev: dev:public','Python tests: test:python, test:python:smoke, test:python:unit','Playwright: test:public, test:api:e2e'].join('\\n'))\"",
    "// services": "=== SERVICE STARTUP ===",
    "dev:backend": "npm run dev:cofounder",
    "dev:cofounder": "cd src/cofounder_agent && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000 --log-level info",
    "dev:frontend": "npm run dev:public",
    "dev:public": "npm run dev --workspace=web/public-site",
    "// setup": "=== SETUP AND ENVIRONMENT ===",
    "install:all": "npm install && npm install --workspaces && npm run setup:python",
    "setup": "npm run install:all && npm run setup:env",
    "setup:dev": "npm run setup:env",
    "setup:python": "poetry install",
    "setup:env": "node scripts/select-env.js",
    "link:env": "node scripts/link-env.js",
    "env:select": "node scripts/select-env.js",
    "clean": "rimraf --glob node_modules package-lock.json yarn.lock **/node_modules **/dist **/.next **/build .venv __pycache__ **/__pycache__ **/*.pyc",
    "clean:install": "npm run clean && npm run install:all",
    "// build": "=== BUILD AND QUALITY ===",
    "build:frontend": "npm run build --workspace=web/public-site --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format:python": "cd src/cofounder_agent && python -m black . && python -m isort .",
    "type:check": "cd src/cofounder_agent && python -m mypy --config-file=../../pyproject.toml",
    "type:check:strict": "cd src/cofounder_agent && python -m mypy --config-file=../../pyproject.toml --strict",
    "lint:python": "cd src/cofounder_agent && python -m pylint src/ --disable=C0111,C0103,W0612",
    "lint:python:sql": "cd src/cofounder_agent && python -m pylint src/ --disable=all --enable=E0001,E0101,E0203,E0211,E0213,E1121,E1123,E1136,E1200,E1201,E1205,E1206,E1300,E1301,E1302,E1303,E1304,E1305,E1306,E1307,E1401,E1999",
    "// python": "=== PYTHON TESTING ===",
    "test:python": "poetry run pytest tests/unit/ tests/integration/ tests/e2e/ -v --tb=short",
    "test:python:integration": "poetry run pytest tests/integration/ -v --tb=short -m integration",
    "test:python:e2e": "poetry run pytest tests/e2e/ -v --tb=short -m e2e",
    "test:python:unit": "poetry run pytest tests/unit/ -v --tb=short",
    "test:python:smoke": "poetry run pytest tests/ -k \"smoke or quick\" -v --tb=short 2>&1 | tail -50",
    "test:python:coverage": "poetry run pytest tests/integration tests/e2e -v --cov --cov-report=html",
    "test:python:performance": "poetry run pytest tests/integration tests/e2e -v -m performance --tb=short",
    "test:python:concurrent": "poetry run pytest tests/integration -v -m concurrent --tb=short",
    "test:api": "poetry run pytest tests/integration/test_api_integration.py -v --tb=short",
    "benchmark": "cd src/cofounder_agent && poetry run pytest tests/benchmarks/ --benchmark-only -v --benchmark-sort=mean",
    "benchmark:ci": "cd src/cofounder_agent && poetry run pytest tests/benchmarks/ --benchmark-only --benchmark-json=../../benchmark_results.json",
    "benchmark:compare": "cd src/cofounder_agent && poetry run pytest tests/benchmarks/ --benchmark-compare=../../benchmark_results.json",
    "// web-tests": "=== FRONTEND AND E2E TESTING ===",
    "test:watch": "npm run test --workspaces --if-present -- --watch",
    "test:coverage": "npm run test --workspaces --if-present -- --coverage",
    "test:ci": "npm run test --workspace=web/public-site --if-present -- --ci --coverage --watchAll=false --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "test:public": "playwright test --config=playwright.config.ts",
    "test:public:chrome": "playwright test --config=playwright.config.ts --project=chromium",
    "test:public:mobile": "playwright test --config=playwright.config.ts --project='Pixel 5'",
    "test:public:tablet": "playwright test --config=playwright.config.ts --project='iPad Pro'",
    "test:public:headed": "playwright test --config=playwright.config.ts --headed",
    "test:public:debug": "playwright test --config=playwright.config.ts --debug",
    "test:api:e2e": "playwright test --config=playwright.api.config.ts",
    "test:api:perf": "playwright test --config=playwright.api.config.ts --project=api-performance",
    "test:api:security": "playwright test --config=playwright.api.config.ts --project=api-security",
    "test:api:smoke": "playwright test --config=playwright.api.config.ts --project=api-smoke",
    "test:smoke": "playwright test -g @smoke",
    "test:critical": "playwright test -g @critical",
    "test:a11y": "playwright test --project='*-a11y'",
    "test:visual": "playwright test --project='*-visual'",
    "test:quick": "npm test && npm run test:smoke",
    "test:all": "npm run test && npm run test:e2e",
    "test:all:ci": "npm run test:ci && npm run test:e2e",
    "test:reports": "npm run test:e2e:report",
    "test:unified": "node scripts/test-runner.js",
    "test:unified:coverage": "npm run test:unified -- --coverage",
    "test:unified:debug": "npm run test:unified -- --debug",
    "// maintenance": "=== VERSIONING AND DOCS ===",
    "bump-version": "node scripts/bump-version.js",
    "bump-version:auto": "npm run bump-version",
    "bump-version:patch": "node scripts/bump-version.js -- --patch",
    "bump-version:minor": "node scripts/bump-version.js -- --minor",
    "bump-version:major": "node scripts/bump-version.js -- --major",
    "docs:cleanup": "bash scripts/cleanup-docs.sh || powershell -ExecutionPolicy Bypass -File cleanup-docs.ps1",
    "docs:cleanup:ps": "powershell -ExecutionPolicy Bypass -File cleanup-docs.ps1",
    "docs:cleanup:sh": "bash scripts/cleanup-docs.sh",
    "prepare": "node -e \"process.exit(process.env.CI || process.env.VERCEL ? 0 : 1)\" || husky",
    "// validation": "=== VALIDATION ===",
    "validate:env": "node scripts/validate-env.js",
    "validate:all": "npm run format:check && npm run lint && npm run validate:env && npm run type:check",
    "// audit": "=== AUDIT AGENTS ===",
    "audit": "node scripts/generate-audit-manifest.js && bash scripts/run-auditors.sh",
    "audit:manifest": "node scripts/generate-audit-manifest.js",
    "audit:dry-run": "node scripts/generate-audit-manifest.js && bash scripts/run-auditors.sh --dry-run"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "baseline-browser-mapping": "^2.9.11",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.3.3",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "svgo": "^2.8.0",
    "@svgr/webpack": "^6.5.1",
    "postcss": "^8.4.47",
    "undici": "^6.21.2",
    "esbuild": ">=0.24.4",
    "nth-check": ">=2.1.1",
    "minimatch": ">=9.0.7",
    "jsonpath": ">=1.1.2",
    "underscore": ">=1.13.7"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.0",
    "@rollup/rollup-linux-x64-musl": "^4.60.0"
  }
}
