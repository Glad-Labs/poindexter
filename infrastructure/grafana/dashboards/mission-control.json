      "description": "Content tasks created in the last 24h. Zero for extended periods means autonomous topic generation has stalled.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
