{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [
    {
      "title": "Uptime Kuma UI",
      "url": "http://localhost:3002",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Monitor status",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "monitor_status",
          "legendFormat": "{{monitor_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" },
                "2": { "text": "PENDING", "color": "yellow" },
                "3": { "text": "MAINT", "color": "blue" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      }
    },
    {
      "type": "timeseries",
      "title": "Response time (ms) by monitor",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "targets": [
        {
          "expr": "monitor_response_time",
          "legendFormat": "{{monitor_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Uptime % (30m rolling)",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "avg_over_time(monitor_status[30m])",
          "legendFormat": "{{monitor_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "TLS days remaining (HTTPS monitors)",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 18 },
      "id": 4,
      "targets": [
        {
          "expr": "monitor_cert_days_remaining",
          "legendFormat": "{{monitor_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 14, "color": "yellow" },
              { "value": 30, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "orientation": "horizontal" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["observability", "uptime", "kuma"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Uptime — Kuma",
  "uid": "obs-uptime",
  "version": 1,
  "weekStart": ""
}
