{
  "uid": "pipeline-overview",
  "title": "Content Pipeline Overview",
  "description": "Content task pipeline monitoring -- status, velocity, and stage distribution",
  "tags": ["glad-labs", "pipeline", "content"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "refresh": "5m",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Tasks by Status",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "completed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "in_progress" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "blue", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pending" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "yellow", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT status, COUNT(*) as count FROM content_tasks GROUP BY status",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tasks Created per Day",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Tasks",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "hue",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT date_trunc('day', created_at) as time, COUNT(*) as tasks_created FROM content_tasks WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "title": "Task Success Rate (7d)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE status = 'completed') * 100.0 / NULLIF(COUNT(*), 0), 1) as success_rate FROM content_tasks WHERE created_at > NOW() - INTERVAL '7 days'",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pipeline Stage Distribution",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Tasks",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT stage, COUNT(*) as count FROM content_tasks WHERE status = 'in_progress' GROUP BY stage",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 5,
      "title": "Avg Time to Completion (7d)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "gladlabs-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "m",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gladlabs-postgres"
          },
          "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM (updated_at - created_at)) / 60), 1) as avg_minutes FROM content_tasks WHERE status = 'completed' AND created_at > NOW() - INTERVAL '7 days'",
          "format": "table",
          "editorMode": "code"
        }
      ]
    }
  ]
}
