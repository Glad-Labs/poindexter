        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_active AS (\n  SELECT id\n    FROM experiments\n   WHERE status = 'active'\n   ORDER BY activated_at DESC NULLS LAST\n   LIMIT 1\n)\nSELECT\n  s.variant_label                         AS \"Variant\",\n  s.posts_attempted                       AS \"Runs\",\n  COALESCE(s.approval_rate_pct, 0)::float AS \"Approval %\",\n  COALESCE(\n    ROUND(AVG(lo.atom_quality_score)::numeric, 1),\n    0\n  )::float                                AS \"Mean Quality Score\",\n  COALESCE(s.avg_edit_distance_pct, 0)::float    AS \"Mean Edit Distance\",\n  COALESCE(s.avg_cost_per_post, 0)::float        AS \"Mean Cost (USD)\",\n  COALESCE(\n    ROUND((AVG(lo.elapsed_ms) / 1000.0)::numeric, 2),\n    0\n  )::float                                AS \"Mean Wall-Clock (s)\"\nFROM experiment_variant_scorecard_v1 s\nJOIN latest_active la ON la.id = s.experiment_id\nLEFT JOIN lab_outcomes_v1 lo ON lo.variant_id = s.variant_id\nGROUP BY s.variant_label, s.posts_attempted, s.approval_rate_pct,\n         s.avg_edit_distance_pct, s.avg_cost_per_post\nORDER BY \"Approval %\" DESC, \"Runs\" DESC;",
          "refId": "A"
        }
      ]
    },
