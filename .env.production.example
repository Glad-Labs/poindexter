# ==================================
# Railway Production Environment Variables
# ==================================
# Set these in Railway Dashboard > Service > Variables
# Generate secrets with: openssl rand -base64 32
#
# CRITICAL: The app will refuse to start without these set correctly.

# --- ENVIRONMENT ---
ENVIRONMENT=production
NODE_ENV=production
LOG_LEVEL=INFO

# --- SECRETS (generate unique values!) ---
SECRET_KEY=<openssl rand -base64 32>
JWT_SECRET_KEY=<openssl rand -base64 32>
JWT_SECRET=<same as JWT_SECRET_KEY>

# --- DATABASE (Railway provides this automatically if Postgres is attached) ---
DATABASE_URL=postgresql://user:pass@host:port/railway

# --- AI MODELS (at least one required) ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# GOOGLE_API_KEY=AIza...

# --- DEPLOYMENT MODE ---
# "coordinator" = cloud (Railway, always-on, CMS + queue + webhooks)
# "worker" = local PC (GPU compute, pipeline execution)
DEPLOYMENT_MODE=coordinator

# --- CORS ---
ALLOWED_ORIGINS=https://glad-labs.com,https://www.glad-labs.com

# --- OPTIONAL ---
PEXELS_API_KEY=<for image search>
SERPER_API_KEY=<for web search in research agent>
REDIS_ENABLED=false
ENABLE_TRACING=false
DEVELOPMENT_MODE=false
RATE_LIMIT_PER_MINUTE=300
