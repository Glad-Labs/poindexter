{
  "uid": "quality-metrics",
  "title": "Quality Metrics",
  "description": "Scores",
  "tags": ["glad-labs"],
  "editable": true,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "text": {
          "valueSize": 28
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(overall_score)::numeric,1) FROM quality_evaluations WHERE evaluation_timestamp>NOW()-INTERVAL '30 days'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pass %",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "text": {
          "valueSize": 28
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE overall_score>=70)*100.0/NULLIF(COUNT(*),0),1) FROM quality_evaluations WHERE evaluation_timestamp>NOW()-INTERVAL '30 days'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Evals",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "text": {
          "valueSize": 28
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM quality_evaluations",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rejected",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "text": {
          "valueSize": 28
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) FROM content_tasks WHERE status='rejected'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Grades",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN overall_score>=80 THEN 'A (80+)' WHEN overall_score>=70 THEN 'B (70-79)' WHEN overall_score>=60 THEN 'C (60-69)' ELSE 'D (<60)' END as grade, COUNT(*) as count, ROUND(AVG(overall_score)::numeric,1) as avg FROM quality_evaluations GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Daily",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day',evaluation_timestamp)::date as day, COUNT(*) as evals, ROUND(AVG(overall_score)::numeric,1) as avg, MIN(overall_score) as min, MAX(overall_score) as max FROM quality_evaluations GROUP BY 1 ORDER BY 1 DESC LIMIT 14",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "railway-prod-db"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT LEFT(ct.topic,45) as topic, ct.quality_score as score, ct.status, ct.created_at::date FROM content_tasks ct WHERE ct.quality_score IS NOT NULL ORDER BY ct.created_at DESC LIMIT 15",
          "refId": "A"
        }
      ]
    }
  ]
}
