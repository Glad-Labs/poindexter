      "id": 16,
      "title": "Spend vs daily limit",
      "type": "gauge",
      "description": "Today's cost_logs.cost_usd sum as a percentage of app_settings.daily_spend_limit_usd. Orange at 80%. Intentionally uses CURRENT_DATE (a calendar-day snapshot) rather than the dashboard time picker — the limit is a daily budget.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 4,
