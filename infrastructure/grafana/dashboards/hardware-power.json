          "rawQuery": true,
          "rawSql": "SELECT sampled_at AS time, metric_value AS value FROM sensor_samples WHERE source='corsair_csv' AND metric_name='psu_power_in' AND $__timeFilter(sampled_at) ORDER BY sampled_at DESC LIMIT 1",
