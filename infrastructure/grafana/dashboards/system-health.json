    {
      "id": 5,
      "title": "Table Row Counts",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "estimated_rows"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 10000
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-blues"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "estimated_rows",
            "desc": true
          }
        ],
        "footer": {
          "show": true,
          "reducer": ["sum"],
          "fields": ["estimated_rows"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT schemaname, relname as table_name, n_live_tup as estimated_rows, n_dead_tup as dead_rows, last_vacuum, last_autovacuum, last_analyze FROM pg_stat_user_tables ORDER BY n_live_tup DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 6,
      "title": "Table Sizes",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Size",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "axisFontSize": 14
          },
          "unit": "decbytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "xTickLabelRotation": 0,
        "xTickLabelMaxLength": 20,
        "barWidth": 0.8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT relname as table_name, pg_total_relation_size(quote_ident(relname)) as total_size_bytes FROM pg_stat_user_tables ORDER BY total_size_bytes DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 7,
      "title": "Index Usage",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "idx_scan_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 50
                    },
                    {
                      "color": "green",
                      "value": 90
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "total_scans",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT relname as table_name, idx_scan as index_scans, seq_scan as sequential_scans, (idx_scan + seq_scan) as total_scans, CASE WHEN (idx_scan + seq_scan) > 0 THEN ROUND(idx_scan * 100.0 / (idx_scan + seq_scan), 1) ELSE 0 END as idx_scan_pct FROM pg_stat_user_tables WHERE (idx_scan + seq_scan) > 0 ORDER BY total_scans DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active Queries",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "query"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 500
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "duration_seconds"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 5
                    },
                    {
                      "color": "red",
                      "value": 30
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "duration_seconds",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT pid, usename, state, EXTRACT(EPOCH FROM (NOW() - query_start)) as duration_seconds, LEFT(query, 200) as query FROM pg_stat_activity WHERE datname = current_database() AND state != 'idle' AND pid != pg_backend_pid() ORDER BY query_start ASC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 9,
