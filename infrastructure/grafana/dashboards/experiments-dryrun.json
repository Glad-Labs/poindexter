    {
      "id": 2,
      "type": "stat",
      "title": "Gate today",
      "description": "Total auto_publish_gate evaluations logged in the last 24h. One per dev_diary finalize.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM audit_log WHERE event_type = 'auto_publish_gate' AND timestamp > NOW() - INTERVAL '24 hours'"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Would-fire 24h",
      "description": "Gate decisions where would_fire=true. While dry_run=true (default), these are the candidate auto-publishes — compare against your actual approves before flipping the gate live.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM audit_log WHERE event_type = 'auto_publish_gate' AND (details->>'would_fire')::boolean = true AND timestamp > NOW() - INTERVAL '24 hours'"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Trailing-7 mean edit distance — dev_diary",
      "description": "Mean char-level edit distance across the last 7 dev_diary publishes. Trending toward 0 means operator edits are minimal — the gate is closer to ready to flip live.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "orange",
                "value": 200
              }
            ]
          },
          "min": 0,
          "max": 500,
          "unit": "none"
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(AVG(char_diff_count)::numeric, 1) AS value FROM ( SELECT char_diff_count FROM published_post_edit_metrics WHERE category = 'dev_diary' OR niche_slug = 'dev_diary' ORDER BY approved_at DESC LIMIT 7 ) t"
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Gate state distribution (last 7 days)",
      "description": "Where the gate landed per evaluation: pass means it would have auto-published; block_threshold/block_structural/block_unclean/no_history/disabled mean it correctly held back.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "none"
        }
      },
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "values": ["value"]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT details->>'gate_state' AS metric, COUNT(*) AS value FROM audit_log WHERE event_type = 'auto_publish_gate' AND timestamp > NOW() - INTERVAL '7 days' GROUP BY details->>'gate_state' ORDER BY value DESC"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Edit distance per publish (per niche)",
      "description": "Char-level edit distance between pre-approve and post-approve content for every published post. Lower = operator made fewer/smaller edits = system output is closer to publish-ready.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 6,
            "showPoints": "always",
            "fillOpacity": 10
          },
          "unit": "none"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT approved_at AS time, COALESCE(NULLIF(niche_slug, ''), category, 'unknown') AS metric, char_diff_count AS value FROM published_post_edit_metrics WHERE approved_at > NOW() - INTERVAL '30 days' ORDER BY approved_at"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Trailing-7 clean-run count by niche",
      "description": "Clean = char_diff_count < dev_diary_auto_publish_max_edit_distance (default 50). Once a niche shows 3 clean runs in its trailing 7, the gate's clean-run criterion is satisfied for that niche.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "blue",
                "value": 3
              }
            ]
          },
          "min": 0,
          "max": 7,
          "unit": "none"
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(NULLIF(niche_slug, ''), category, 'unknown') AS niche, SUM(CASE WHEN char_diff_count < 50 THEN 1 ELSE 0 END) AS value FROM ( SELECT niche_slug, category, char_diff_count, ROW_NUMBER() OVER (PARTITION BY COALESCE(NULLIF(niche_slug, ''), category) ORDER BY approved_at DESC) AS rn FROM published_post_edit_metrics ) t WHERE rn <= 7 GROUP BY COALESCE(NULLIF(niche_slug, ''), category, 'unknown')"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent gate decisions (last 20)",
      "description": "Each finalize_task evaluation. would_fire=true and dry_run=true means the gate would have auto-published if you flip dry_run off — worth comparing against your actual approve decision for this task.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "would_fire"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "color": "blue",
                        "text": "WOULD FIRE"
                      },
                      "false": {
                        "color": "orange",
                        "text": "blocked"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "gate_state"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background-solid"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "pass": {
                        "color": "blue"
                      },
                      "block_threshold": {
                        "color": "yellow"
                      },
                      "block_structural": {
                        "color": "red"
                      },
                      "block_unclean": {
                        "color": "orange"
                      },
                      "disabled": {
                        "color": "blue"
                      },
                      "no_history": {
                        "color": "purple"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT timestamp AS \"time\", task_id, details->>'gate_state' AS gate_state, (details->>'would_fire')::boolean AS would_fire, (details->>'dry_run')::boolean AS dry_run, ROUND((details->>'quality_score')::numeric, 1) AS quality_score, ROUND((details->>'threshold')::numeric, 1) AS threshold, details->>'reason' AS reason FROM audit_log WHERE event_type = 'auto_publish_gate' ORDER BY timestamp DESC LIMIT 20"
        }
      ]
    },
