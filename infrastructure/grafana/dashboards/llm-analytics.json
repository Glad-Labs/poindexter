{
  "uid": "llm-analytics",
  "title": "LLM Analytics — Ollama Inference Metrics",
  "description": "Inference calls, latency, token usage, cost breakdown, quality scores, and model performance",
  "tags": ["glad-labs", "llm", "ollama", "inference"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "refresh": "15m",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Inference Calls Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Calls",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, model, COUNT(*) AS calls FROM cost_logs WHERE $__timeFilter(created_at) GROUP BY 1, model ORDER BY 1",
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average Inference Latency by Model",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 0 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT model, ROUND(AVG(duration_ms)::numeric, 0) AS avg_latency_ms FROM cost_logs WHERE duration_ms IS NOT NULL AND $__timeFilter(created_at) GROUP BY model ORDER BY avg_latency_ms DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Tokens",
            "drawStyle": "line",
            "fillOpacity": 40,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "input_tokens" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "semi-dark-blue", "mode": "fixed" }
              },
              { "id": "displayName", "value": "Input Tokens" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "output_tokens" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "semi-dark-green", "mode": "fixed" }
              },
              { "id": "displayName", "value": "Output Tokens" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, SUM(input_tokens) AS input_tokens, SUM(output_tokens) AS output_tokens FROM cost_logs WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cost by Provider",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT provider, COALESCE(SUM(cost_usd), 0) AS cost FROM cost_logs WHERE $__timeFilter(created_at) GROUP BY provider ORDER BY cost DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 5,
      "title": "Model Usage Breakdown",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT model, COUNT(*) AS calls FROM cost_logs WHERE $__timeFilter(created_at) GROUP BY model ORDER BY calls DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 6,
      "title": "Quality Score Trend",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "semi-dark-purple", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Quality Score",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 6,
            "showPoints": "always",
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(255, 0, 0, 0.05)", "value": 0 },
              { "color": "transparent", "value": 7 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 10,
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT date_trunc('day', created_at) AS time, AVG(quality_score) AS avg_quality FROM content_tasks WHERE quality_score IS NOT NULL AND $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 7,
      "title": "Quality Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 30 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 4 },
              { "color": "yellow", "value": 6 },
              { "color": "green", "value": 7 },
              { "color": "dark-green", "value": 9 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 10
        },
        "overrides": []
      },
      "options": {
        "bucketSize": 1,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT quality_score FROM content_tasks WHERE quality_score IS NOT NULL AND $__timeFilter(created_at)",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 8,
      "title": "Content Generation Success Rate",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 30 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pass" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              },
              { "id": "displayName", "value": "Pass (>= 7.0)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              },
              { "id": "displayName", "value": "Fail (< 7.0)" }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT COUNT(*) FILTER (WHERE passing = true) AS pass, COUNT(*) FILTER (WHERE passing = false) AS fail FROM quality_evaluations WHERE $__timeFilter(evaluation_timestamp)",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 9,
      "title": "Average Quality by Model",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 40 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "max": 10,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "yellow", "value": 6.5 },
              { "color": "green", "value": 7 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "colorByField": "avg_quality",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT cl.model, ROUND(AVG(qe.overall_score)::numeric, 1) AS avg_quality FROM quality_evaluations qe JOIN content_tasks ct ON qe.task_id = ct.task_id JOIN cost_logs cl ON cl.task_id = ct.task_id WHERE $__timeFilter(qe.evaluation_timestamp) GROUP BY cl.model ORDER BY avg_quality DESC",
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 10,
      "title": "Total Tokens Processed",
      "type": "stat",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 40 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "semi-dark-blue", "mode": "fixed" },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT COALESCE(SUM(input_tokens + output_tokens), 0) AS \"Total Tokens\" FROM cost_logs WHERE $__timeFilter(created_at)",
          "format": "table",
          "editorMode": "code"
        }
      ]
    }
  ]
}
