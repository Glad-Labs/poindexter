# ==================================
# Glad Labs - Environment Configuration
# ==================================
# 
# QUICK START:
# 1. Copy this file: cp .env.example .env.local
# 2. Edit .env.local with your values (NEVER commit real secrets!)
# 3. For AI models, choose AT LEAST ONE: Ollama (free), OpenAI, Anthropic, or Google
# 4. For database: PostgreSQL glad_labs_dev is REQUIRED (no SQLite fallback)
#
# For detailed setup and canonical env reference:
# - docs/reference/ENVIRONMENT_SETUP.md
# - docs/reference/GITHUB_SECRETS_SETUP.md
#

# ==================================
# ENVIRONMENT & LOGGING
# ==================================
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEBUG=false

# ==================================
# PORT CONFIGURATION
# ==================================
# Backend: FastAPI (Python) - AI orchestrator and API server
COFOUNDER_AGENT_PORT=8000

# Frontend: React apps
PUBLIC_SITE_PORT=3000           # Next.js public website
OVERSIGHT_HUB_PORT=3001         # React admin/oversight interface

# Database
POSTGRES_PORT=5432
# REDIS_PORT=6379  # Optional - for production caching only

# ==================================
# DATABASE CONFIGURATION - REQUIRED ✅
# ==================================
# PostgreSQL is MANDATORY (no SQLite fallback for production)
# Database: glad_labs_dev (development) or glad_labs_prod (production)
#
# Setup: psql -U postgres -c "CREATE DATABASE glad_labs_dev;"
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/glad_labs_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=glad_labs_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Optional: Connection pool sizing
# DATABASE_POOL_MIN_SIZE=10
# DATABASE_POOL_MAX_SIZE=20

# ==================================
# AI MODEL SELECTION - CHOOSE ONE
# ==================================
# 🤖 OPTION 1: FREE LOCAL AI (Recommended for Development)
# ✅ Zero cost, unlimited requests, runs completely offline
# Requires: Ollama installed (https://ollama.ai) and running
# Models: mistral (7B), llama2 (7B), phi (2.7B), neural-chat, etc.
#
# To use: ollama pull mistral && ollama serve
# Canonical variable: OLLAMA_BASE_URL
# Backward-compatible alias accepted by some modules: OLLAMA_HOST
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# 🤖 OPTION 2: OPENAI (ChatGPT)
# Cost: $0.50-$30/month depending on usage
# Models: gpt-4-turbo, gpt-4, gpt-3.5-turbo
# Get API key: https://platform.openai.com/api-keys
# ⚠️ Requires OPENAI_API_KEY to be set if using OpenAI
# OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 🤖 OPTION 3: ANTHROPIC CLAUDE
# Cost: $0.80-$5/month depending on usage
# Models: claude-opus, claude-sonnet, claude-haiku
# Get API key: https://console.anthropic.com
# ⚠️ Requires ANTHROPIC_API_KEY to be set if using Anthropic
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 🤖 OPTION 4: GOOGLE GEMINI
# Cost: Free tier available + paid (varies by model)
# Models: gemini-pro, gemini-pro-vision, gemini-2.0
# Get API key: https://aistudio.google.com/app/apikey
# ⚠️ Requires GOOGLE_API_KEY to be set if using Google
# GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 🤖 OPTION 5: HUGGINGFACE (Free Tier)
# Cost: Free for inference API (rate limited)
# Models: mistral-7b-instruct, zephyr-7b, openchat-3.5, etc.
# Get token: https://huggingface.co/settings/tokens
# ⚠️ Optional, only set if using HuggingFace
# HUGGINGFACE_API_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ==================================
# FRONTEND CONFIGURATION
# ==================================
# 🌐 NEXT.JS PUBLIC SITE (web/public-site)
# WHY NEXT_PUBLIC_ PREFIX?
#   Next.js only bundles env vars with the NEXT_PUBLIC_ prefix into client-side
#   code. Server-only vars (no prefix) are never exposed to the browser.
#   See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
# API endpoints and URLs the Next.js public site uses
# Most source files use NEXT_PUBLIC_API_BASE_URL; NEXT_PUBLIC_FASTAPI_URL is used by
# next.config.js and a subset of app routes. Set both to the same backend URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
# Used in web/public-site/lib/posts.ts as the fallback API base URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Used by the backend revalidate_routes.py to trigger ISR cache clearing for the public site
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3000

# ISR Cache Revalidation (generate with: openssl rand -base64 32)
# Used by web/public-site/app/api/revalidate/route.js and src/cofounder_agent/routes/revalidate_routes.py
# WARNING: Defaults to 'dev-secret-key' if not set — always override in production!
REVALIDATE_SECRET=change-me-in-production

# 💬 GISCUS - GitHub Discussions Comments
# Giscus powers blog post comments using GitHub Discussions
#
# Setup Instructions:
# 1. Create a public GitHub repository (or use existing)
# 2. Enable Discussions: Settings → Features → Enable Discussions
# 3. Go to https://giscus.app
# 4. Connect your GitHub repository
# 5. Copy the Repo ID and Category ID from giscus.app
# 6. Fill in the values below:
#
# Repo format: username/repository (e.g., Glad-Labs/glad-labs-codebase)
NEXT_PUBLIC_GISCUS_REPO=username/repo-name
# Repo ID: Found on giscus.app (e.g., R_kgDOQInTBg)
NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDOXXXXXXXXX
# Category ID: Found on giscus.app (e.g., DIC_kwDOQInTBs4CxB4O)
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOXXXXXXXXX

# Optional: Google Analytics (leave blank for development)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GA4_ID=

# 📊 REACT OVERSIGHT HUB (web/oversight-hub)
# Admin interface for monitoring and controlling agents
#
# WHY DIFFERENT PREFIXES FROM NEXT.JS?
#   - Next.js (web/public-site) exposes client-side vars with NEXT_PUBLIC_ prefix
#     (Next.js convention — only NEXT_PUBLIC_* vars are bundled into client code)
#   - Create React App (web/oversight-hub) exposes vars with REACT_APP_ prefix
#     (CRA convention — only REACT_APP_* vars are exposed at build time)
#
# RECOMMENDED (CRA-standard):
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_WS_BASE_URL=http://localhost:8000
REACT_APP_AGENT_URL=http://localhost:8000
REACT_APP_LOG_LEVEL=debug
REACT_APP_GH_OAUTH_CLIENT_ID=your_github_client_id_here
REACT_APP_USE_MOCK_AUTH=false
REACT_APP_SENTRY_DSN=https://your_sentry_dsn@sentry.io/1234567890

# Optional: Ollama local model server (for AI Studio)
# Only required if using local Ollama models in AI Studio component
# oversight-hub uses Vite (not CRA), so the correct prefix is VITE_:
# VITE_OLLAMA_URL=http://localhost:11434
# Legacy CRA alias (stale — oversight-hub migrated to Vite):
# REACT_APP_OLLAMA_URL=http://localhost:11434

# Optional: Public site URL for link generation from admin UI
# REACT_APP_PUBLIC_SITE_URL=http://localhost:3000

# ==================================
# SECURITY & AUTHENTICATION
# ==================================
# Development auth bypass — accepts "Bearer dev-token" as valid auth.
# NEVER set to true in production. Only used for local development without GitHub OAuth.
DEVELOPMENT_MODE=false

# JWT Secret for API authentication
# ⚠️ CHANGE THIS IN PRODUCTION! Generate: openssl rand -base64 32
# Canonical variable: JWT_SECRET_KEY
# Backward-compatible alias: JWT_SECRET
JWT_SECRET_KEY=dev-jwt-secret-change-in-production-to-random-64-chars
JWT_SECRET=dev-jwt-secret-change-in-production-to-random-64-chars

# GitHub OAuth Configuration
# Note: Use GH_OAUTH_ prefix instead of GITHUB_ because GitHub Actions blocks GITHUB_ secrets
# Get credentials: https://github.com/settings/developers → OAuth Apps
# Set Authorization callback URL to: http://localhost:3001/auth/callback (dev) or https://yourdomain.com/auth/callback (prod)
GH_OAUTH_CLIENT_ID=your_github_client_id_here
GH_OAUTH_CLIENT_SECRET=your_github_client_secret_here

# Cookie-Based Authentication (HttpOnly Secure Cookies)
# ⚠️ Security: Protects against XSS token theft (localStorage vulnerability)
# Backend sets HttpOnly cookies; frontend uses credentials: 'include'
AUTH_COOKIE_NAME=gladlabs_auth
AUTH_COOKIE_SECURE=false                    # Set to true in production (requires HTTPS)
AUTH_COOKIE_MAX_AGE_SECONDS=86400           # 24 hours (adjust as needed)

# CORS: Allowed origins for cross-origin requests (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ==================================
# RATE LIMITING
# ==================================
# Requests per minute per IP address
RATE_LIMIT_PER_MINUTE=100

# API timeout (milliseconds)
API_TIMEOUT=30000

# API retry attempts
API_RETRY_ATTEMPTS=2

# ==================================
# REDIS CACHE (Optional - Production Only)
# ==================================
# For local development: in-memory cache is used (no Redis needed)
# For production: configure Redis for distributed caching
#
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# ==================================
# OBSERVABILITY & ERROR TRACKING
# ==================================
# Sentry (error tracking) - Optional
# Leave blank to disable error tracking in development
# SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id
#
# Public site (Next.js) Sentry DSN — set in web/public-site/.env.local
# Used in web/public-site/sentry.client.config.ts and next.config.js
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-key@sentry.io/your-public-site-project-id
#
# Admin UI (Oversight Hub) — set in web/oversight-hub/.env.local
# REACT_APP_SENTRY_DSN=https://your-sentry-key@sentry.io/your-admin-project-id

# Tracing (performance monitoring) - Optional
# ENABLE_TRACING=true or false (default: false in development)
# When ENABLE_TRACING=true you MUST also set OTEL_EXPORTER_OTLP_ENDPOINT, otherwise
# traces are generated but silently dropped (no local OTLP collector in Railway).
# Example backends: Grafana Tempo, Honeycomb, Jaeger
ENABLE_TRACING=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces  # or your Grafana Tempo URL
# Database Query Performance Monitoring - Optional
# Log slow database queries to identify performance bottlenecks
# Tracks execution time, result count, and query context
ENABLE_QUERY_MONITORING=true       # Enable/disable query monitoring (default: true)
SLOW_QUERY_THRESHOLD_MS=100        # Warn if query takes longer than this (ms)
LOG_ALL_QUERIES=false              # Log all queries regardless of performance (debug mode)


# ==================================
# FEATURE FLAGS
# ==================================
ENABLE_DEBUG_LOGS=true
ENABLE_ANALYTICS=false              # Development: disabled by default
ENABLE_ERROR_REPORTING=false        # Development: disabled by default
ENABLE_MCP_SERVER=true              # Model Context Protocol support
ENABLE_MEMORY_SYSTEM=true           # AI memory/learning system

# ==================================
# OTHER CONFIGURATIONS
# ==================================
# Pexels API Key (for image search)
PEXELS_API_KEY=YOUR_PEXELS_API_KEY_HERE

SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE

# AdSense (optional - for displaying ads on public site)
# NEXT_PUBLIC_ADSENSE_ID=your_adsense_id
