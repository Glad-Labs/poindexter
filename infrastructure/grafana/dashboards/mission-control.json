      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN COALESCE(lim.value::numeric, 0) = 0 THEN 0 ELSE LEAST(100, ROUND((used.spend / lim.value::numeric) * 100, 1))::float END AS \"% of daily limit\" FROM (SELECT COALESCE(SUM(cost_usd),0)::numeric AS spend FROM cost_logs WHERE created_at::date = CURRENT_DATE) used CROSS JOIN (SELECT value FROM app_settings WHERE key='daily_spend_limit_usd') lim;",
          "refId": "A"
        }
      ]
