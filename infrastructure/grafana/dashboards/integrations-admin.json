    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "description": "Retention policies for embeddings_orphan_prune and embeddings_collapse. Orphan prune deletes embeddings whose parent row is gone; collapse clusters old same-source embeddings into a summary paragraph then deletes the originals. All seeded enabled=false. Enable: poindexter retention enable <name>. Tune: poindexter retention config set <name> KEY=VALUE.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Enabled"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "text": "enabled",
