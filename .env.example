# Poindexter — environment template for the single-container quickstart
# (docker-compose.yml). Copy this file to `.env` and fill in the values
# the compose stack reads:
#
#   cp .env.example .env
#   # edit .env, then:
#   docker compose up -d
#
# Variables with a `${VAR:-default}` in docker-compose.yml are OPTIONAL —
# the listed default is used when left blank. Variables with `${VAR:?...}`
# are REQUIRED — the stack refuses to start until they are set.
#
# For the full operator stack (docker-compose.local.yml: Grafana, pgAdmin,
# Prometheus, GlitchTip, etc.) run `poindexter setup` instead — it writes
# the machine secrets to ~/.poindexter/bootstrap.toml.

# ============================================================
# PostgreSQL — primary backend DB (the `postgres` service)
# ============================================================
# Optional — defaults shown. Change the password for anything beyond a
# throwaway local run.
POSTGRES_DB=poindexter
POSTGRES_USER=poindexter
POSTGRES_PASSWORD=poindexter-dev

# ============================================================
# Local PostgreSQL + pgvector — brain + ops (the `postgres-local` service)
# ============================================================
# Optional — defaults shown.
LOCAL_POSTGRES_DB=poindexter_brain
LOCAL_POSTGRES_USER=poindexter
LOCAL_POSTGRES_PASSWORD=poindexter-brain-local

# ============================================================
# Grafana — local dashboards (the `grafana` service)
# ============================================================
# GRAFANA_USER is optional (defaults to `admin`).
# GRAFANA_PASSWORD is REQUIRED — Grafana will not start without it.
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-grafana-admin

# ============================================================
# FastAPI backend (the `cofounder` service)
# ============================================================
# Auth is OAuth 2.1 (Client Credentials). No static API token is needed.
# Run `poindexter auth migrate-cli` after `poindexter setup` to provision
# credentials. The legacy API_TOKEN / POINDEXTER_KEY / GLADLABS_KEY env
# vars were removed in poindexter#249 (2026-05-05) — do NOT set them.

# REVALIDATE_SECRET is REQUIRED — shared secret the Next.js site uses to
# trigger ISR revalidation against the backend.
REVALIDATE_SECRET=change-me-revalidate-secret

# Optional — set to `true` to relax auth/debug behavior for local dev.
DEVELOPMENT_MODE=false

# Local LLM endpoint. Optional — defaults to the host's Ollama install
# reached over the docker host gateway. Install Ollama natively on the
# host for free local inference.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# External services — optional. Leave blank to disable the feature.
# PEXELS_API_KEY: stock-image sourcing fallback.
# SERPER_API_KEY: web-search / fact-check topic source.
PEXELS_API_KEY=
SERPER_API_KEY=

# Pipeline settings — optional, defaults shown.
RATE_LIMIT_PER_MINUTE=100
LOG_LEVEL=INFO

# Monitoring (optional). Point SENTRY_DSN at a self-hosted GlitchTip or
# Sentry project to capture runtime errors; SENTRY_ENABLED gates it.
SENTRY_DSN=
SENTRY_ENABLED=false

# OpenClaw webhooks (optional) — push notifications to Discord/Telegram.
OPENCLAW_WEBHOOK_URL=
OPENCLAW_WEBHOOK_TOKEN=

# OpenClaw container (optional) — only used if you uncomment the openclaw
# service in docker-compose.yml.
# OPENCLAW_CONFIG_DIR=~/.openclaw
# TZ=America/New_York
