Modelfile*
*.gguf
scripts/secrets-to-scrub.txt
*.html

# Branded frontend (private — not part of the open-source engine)
web/public-site/


# Premium Grafana dashboards (kept locally for Matt's Grafana, never committed)
infrastructure/grafana/dashboards/cost-analytics.json
infrastructure/grafana/dashboards/infrastructure-data.json

