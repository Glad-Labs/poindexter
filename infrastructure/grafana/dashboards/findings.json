    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "description": "What each emitted kind routes to, joining the live findings.<kind>.delivery app_settings policy. Kinds with no explicit policy show 'route (unconfigured)' — the router deliberately keeps them loud rather than applying findings.default. Edit a policy live with: poindexter (or MCP set_setting) findings.<kind>.delivery = log_only|discord|telegram|auto_fix|github_issue.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 17 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT f.kind AS \"Kind\", f.cnt AS \"Count\", COALESCE(p.value, 'route (unconfigured)') AS \"Delivery Policy\" FROM (SELECT details->>'kind' AS kind, COUNT(*)::int AS cnt FROM audit_log WHERE event_type = 'finding' AND $__timeFilter(timestamp) GROUP BY 1) f LEFT JOIN app_settings p ON p.key = 'findings.' || f.kind || '.delivery' ORDER BY f.cnt DESC;",
          "refId": "A"
        }
      ],
      "title": "Kind → Delivery Policy (window)",
      "type": "table"
    },
