{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (spans/sec) by service",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by service",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_spanmetrics_latency_bucket[5m])))",
          "legendFormat": "p95 {{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Error rate by service",
      "datasource": { "type": "prometheus", "uid": "local-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum by (service_name) (rate(traces_spanmetrics_calls_total[5m]))",
          "legendFormat": "err% {{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "type": "nodeGraph",
      "title": "Service graph",
      "datasource": { "type": "tempo", "uid": "local-tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "queryType": "serviceMap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "traces",
      "title": "Recent errors (TraceQL)",
      "datasource": { "type": "tempo", "uid": "local-tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "query": "{ status = error }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces",
          "limit": 50
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["observability", "tempo", "traces"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Tracing — Tempo",
  "uid": "obs-tempo",
  "version": 1,
  "weekStart": ""
}
