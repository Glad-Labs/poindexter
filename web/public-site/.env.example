# ==========================================================================
# Glad Labs Public Site — Environment Configuration
# ==========================================================================
# Local dev: copy to .env.local and fill in what you need (all optional
# unless the feature is enabled).
# Production: values come from Vercel project env, not this file.
# Never commit real secrets.
# ==========================================================================


# -------- Site identity --------
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_NAME=Glad Labs


# -------- FastAPI backend --------
# Used by preview routes, ViewTracker beacon, and podcast routes.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8002
# NEXT_PUBLIC_FASTAPI_URL=http://localhost:8002   # legacy fallback name


# -------- ISR revalidation --------
# Required in production. Generate: openssl rand -base64 32
# REVALIDATE_SECRET=


# -------- Sentry (optional) --------
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=


# -------- Google Analytics 4 (optional) --------
# Format: G-XXXXXXXXXX — https://analytics.google.com
# NEXT_PUBLIC_GA_ID=


# -------- Google AdSense (optional) --------
# Format: ca-pub-xxxxxxxxxxxxxxxx — https://adsense.google.com
# NEXT_PUBLIC_ADSENSE_ID=
# NEXT_PUBLIC_ADSENSE_SLOT_ID=


# -------- Giscus comments (optional) --------
# Get values from https://giscus.app
# NEXT_PUBLIC_GISCUS_REPO=
# NEXT_PUBLIC_GISCUS_REPO_ID=
# NEXT_PUBLIC_GISCUS_CATEGORY_ID=


# -------- Feature flags --------
# NEXT_PUBLIC_ENABLE_COMMENTS=true
# NEXT_PUBLIC_ENABLE_SEARCH=true
