        "uid": "local-brain-db"
      },
      "description": "Routable findings (warn/critical) above the route watermark — i.e. emitted but NOT yet forwarded to a delivery channel by findings_alert_router. This is the 'unprocessed findings' backlog from #461. Steady-state should be ~0 (the router runs every 60s); a non-zero value that persists means the router is stalled. Not time-windowed — it's a live backlog count.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "color": "blue", "text": "✓ 0" } }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 25 }
            ]
          },
          "unit": "none"
        }
      },
