# ==================================
# AI Content Pipeline — Environment Configuration
# ==================================
#
# QUICK START:
# 1. Copy this file: cp .env.example .env.local
# 2. Edit .env.local with your values (NEVER commit real secrets!)
# 3. For AI models, choose AT LEAST ONE: Ollama (free), OpenAI, Anthropic, or Google
# 4. For database: PostgreSQL is REQUIRED (no SQLite fallback)
# 5. Run: bash scripts/bootstrap.sh
#
# NOTE: Most settings live in the app_settings database table, not here.
# Only secrets and infrastructure endpoints need env vars.
# Everything else is configurable at runtime via the DB.
#

# === Site Identity ===
# These configure your brand throughout the pipeline
SITE_NAME=My Content Site
SITE_DOMAIN=localhost:3000
SITE_URL=https://localhost:3000
API_BASE_URL=http://localhost:8000
SUPPORT_EMAIL=support@example.com
PRIVACY_EMAIL=privacy@example.com
NEWSLETTER_FROM_EMAIL=Newsletter <newsletter@example.com>

# === Company Facts (for content validation / anti-hallucination) ===
COMPANY_NAME=My Company
COMPANY_FOUNDED_DATE=2025-01-01
COMPANY_FOUNDED_YEAR=2025
COMPANY_AGE_MONTHS=12
COMPANY_TEAM_SIZE=1
COMPANY_FOUNDER_NAME=Founder
COMPANY_PRODUCTS=mysite.com,content pipeline
GPU_MODEL=NVIDIA GPU

# === Core Database ===
# PostgreSQL is MANDATORY (no SQLite fallback)
# Setup: psql -U postgres -c "CREATE DATABASE poindexter_dev;"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poindexter_dev
# Cloud DB — optional, for syncing to a remote Postgres (e.g. Supabase, Neon)
# CLOUD_DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=poindexter_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# DATABASE_POOL_MIN_SIZE=10
# DATABASE_POOL_MAX_SIZE=20

# === AI Model Providers ===
# Choose at least ONE provider. The model router auto-selects: Ollama > Anthropic > OpenAI > Google > echo/mock
# Use cost tiers (free/budget/standard/premium/flagship) — never hardcode model names.

# Ollama (free, local — recommended for development)
# Install: https://ollama.ai  |  Start: ollama pull mistral && ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic Claude — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Gemini — https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# === Pipeline Settings ===
# Pexels API key for image sourcing in the content pipeline
PEXELS_API_KEY=YOUR_PEXELS_API_KEY_HERE

# Serper API key for web research
SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE

# Auto-publish quality threshold (0-100). 0 = disabled (manual review required).
AUTO_PUBLISH_THRESHOLD=0

# Daily LLM spend cap in USD. Pipeline stops creating new tasks when reached.
DAILY_BUDGET_USD=5.00

# === OpenClaw Integration ===
# OpenClaw gateway webhook — pipeline events (task.completed, task.failed, etc.)
# are pushed here for forwarding to Discord/Telegram.
# OPENCLAW_WEBHOOK_URL=http://localhost:3400
# OPENCLAW_WEBHOOK_TOKEN=your-shared-secret-here

# === Authentication ===
# Single bearer token for all API access (OpenClaw skills, Grafana, scripts).
# Generate: openssl rand -base64 32
API_TOKEN=change-me-in-production

# Application secret key — REQUIRED in production (app refuses to start with default)
# Generate: openssl rand -base64 32
SECRET_KEY=your-secret-key-here

# Development auth bypass — accepts "Bearer dev-token" as valid auth.
# NEVER set to true in production.
DEVELOPMENT_MODE=false

# CORS: Allowed origins for cross-origin requests (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=100

# === Monitoring ===
# Sentry error tracking (leave blank to disable)
# SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# OpenTelemetry tracing (requires an OTLP collector: Grafana Tempo, Honeycomb, Jaeger)
ENABLE_TRACING=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces

# Database query performance monitoring
ENABLE_QUERY_MONITORING=true
SLOW_QUERY_THRESHOLD_MS=100
LOG_ALL_QUERIES=false

# === Public Site (Next.js) ===
# These are duplicated in web/public-site/.env.example for the Next.js process.
# Static JSON URL — where the frontend reads post data from.
# Set this to your R2/S3 public URL after running the first export.
# NEXT_PUBLIC_STATIC_URL=https://your-r2-bucket.r2.dev/static
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legacy API URL — only needed if you still use the API proxy routes.
# The frontend reads from static JSON by default, not the API.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ISR cache revalidation secret (generate with: openssl rand -base64 32)
REVALIDATE_SECRET=change-me-in-production

# Giscus comments (GitHub Discussions) — get values from https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=username/repo-name
NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDOXXXXXXXXX
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOXXXXXXXXX

# Google Analytics (leave blank for development)
# NEXT_PUBLIC_GA_ID=

# AdSense publisher ID (leave blank for development)
# NEXT_PUBLIC_ADSENSE_ID=

# === Optional / Feature Flags ===
ENABLE_TRAINING_CAPTURE=false
ENABLE_MCP_SERVER=true
ENABLE_MEMORY_SYSTEM=true

# === Self-Hosted Services (docker-compose.local.yml) ===
# These are required when running the local Docker stack.
# LOCAL_POSTGRES_PASSWORD=your-local-postgres-password
# GRAFANA_PASSWORD=your-grafana-admin-password
# PGADMIN_PASSWORD=your-pgadmin-password
# API_TOKEN=your-worker-api-token
# WOODPECKER_GITEA_CLIENT=your-gitea-oauth-client-id
# WOODPECKER_GITEA_SECRET=your-gitea-oauth-secret
# WOODPECKER_SECRET=your-woodpecker-agent-secret
# GITEA_PASSWORD=your-gitea-admin-password
# DB_PASS=your-db-password  (for backup/restore scripts)

# === Ports ===
COFOUNDER_AGENT_PORT=8000
PUBLIC_SITE_PORT=3000
POSTGRES_PORT=5432

# === Deployment Mode ===
# "worker" (default) — runs the full pipeline: API routes, task executor, content
#   generation. This is the standard mode for running on your own machine.
# "coordinator" — lightweight API-only mode (no task execution). Legacy mode for
#   cloud deployments, rarely needed since the static export eliminates the need
#   for a running API server.
DEPLOYMENT_MODE=worker

# === Environment ===
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# === Legacy JWT Auth (still validated at startup — set real values in production) ===
JWT_SECRET_KEY=dev-jwt-secret-change-in-production-to-random-64-chars
JWT_SECRET=dev-jwt-secret-change-in-production-to-random-64-chars
# GH_OAUTH_CLIENT_ID=your_github_client_id_here
# GH_OAUTH_CLIENT_SECRET=your_github_client_secret_here
# AUTH_COOKIE_NAME=poindexter_auth
# AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_MAX_AGE_SECONDS=86400

# === Disabled: Redis eliminated ===
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
