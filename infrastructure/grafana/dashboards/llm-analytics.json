        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "railway-prod-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day',created_at)::date as day, provider, model, COUNT(*) as calls, SUM(input_tokens) as in_tok, SUM(output_tokens) as out_tok, SUM(input_tokens+output_tokens) as total_tok, ROUND(SUM(cost_usd)::numeric,6) as cost FROM cost_logs GROUP BY 1,2,3 ORDER BY 1 DESC, 7 DESC LIMIT 20",
          "refId": "A"
        }
      ]
