            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Pending Delivery\" FROM audit_log WHERE event_type = 'finding' AND severity IN ('warn', 'warning', 'critical') AND id > COALESCE((SELECT NULLIF(value, '')::bigint FROM app_settings WHERE key = 'findings_alert_route_watermark'), 0);",
          "refId": "A"
        }
      ],
      "title": "Pending delivery",
      "type": "stat"
