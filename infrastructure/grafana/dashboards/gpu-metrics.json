{
  "uid": "gpu-metrics",
  "title": "GPU & Power Metrics",
  "description": "RTX 5090 + HX1500i PSU",
  "tags": ["glad-labs", "hardware"],
  "editable": true,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "GPU Util %",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT utilization FROM gpu_metrics ORDER BY \"timestamp\" DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "GPU Temp",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT temperature FROM gpu_metrics ORDER BY \"timestamp\" DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "GPU Power",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 600,
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 360 },
              { "color": "red", "value": 510 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT power_draw FROM gpu_metrics ORDER BY \"timestamp\" DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "VRAM %",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(((memory_used/NULLIF(memory_total,0))*100)::numeric,1) FROM gpu_metrics ORDER BY \"timestamp\" DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "Wall Power (HX1500i)",
      "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1500,
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "orange", "value": 800 },
              { "color": "red", "value": 1200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "psu_power_watts{sensor=\"estimated_input_power\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "DC Output (HX1500i)",
      "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1500,
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "orange", "value": 800 },
              { "color": "red", "value": 1200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "psu_power_watts{sensor=\"total_power_output\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "gauge",
      "title": "CPU Package Power",
      "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 200,
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 150 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "system_cpu_package_power_watts",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Power Over Time",
      "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Watts",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "watt"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Wall Power" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "DC Output" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "GPU" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "blue", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "psu_power_watts{sensor=\"estimated_input_power\"}",
          "legendFormat": "Wall Power",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "psu_power_watts{sensor=\"total_power_output\"}",
          "legendFormat": "DC Output",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "nvidia_gpu_power_draw_watts",
          "legendFormat": "GPU",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "system_cpu_package_power_watts",
          "legendFormat": "CPU",
          "refId": "D"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Electricity Cost (EIA rate)",
      "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "$/day",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "psu_power_watts{sensor=\"estimated_input_power\"} / 1000 * 0.14 * 24",
          "legendFormat": "Est. Daily Cost",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "PSU Temperatures",
      "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "celsius"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "PSU VRM" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "PSU Case" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "psu_temperature_celsius{sensor=\"vrm_temperature\"}",
          "legendFormat": "PSU VRM",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "gpu-prometheus" },
          "expr": "psu_temperature_celsius{sensor=\"case_temperature\"}",
          "legendFormat": "PSU Case",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent GPU Samples",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": []
      },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(\"timestamp\",'HH24:MI') as sample_time, utilization as util, temperature as temp, ROUND(power_draw::numeric) as watts, memory_used as vram, fan_speed as fan, clock_graphics as clock FROM gpu_metrics WHERE \"timestamp\">NOW()-INTERVAL '2 hours' ORDER BY \"timestamp\" DESC LIMIT 20",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Daily GPU Avg",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "local-brain-db"
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": []
      },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day',\"timestamp\")::date as day, ROUND(AVG(utilization)::numeric,1) as util, ROUND(AVG(temperature)::numeric,1) as temp, ROUND(AVG(power_draw)::numeric) as watts, COUNT(*) as samples FROM gpu_metrics GROUP BY 1 ORDER BY 1 DESC LIMIT 7",
          "refId": "A"
        }
      ]
    }
  ]
}
