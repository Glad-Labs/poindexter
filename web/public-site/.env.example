# ==================================
# Glad Labs Public Site - Environment Configuration
# ==================================
# Development: Copy this file to .env.local and fill in your values
# Production: Secrets come from Vercel environment variables
# Never commit real secrets to version control!

# ==================================
# FastAPI CMS API Configuration (REQUIRED)
# ==================================
# This should point to your running FastAPI backend
# Canonical variable (preferred in current code)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Backward-compatible alias (older code paths)
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# ==================================
# Site Configuration (REQUIRED)
# ==================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Glad Labs

# ==================================
# Google Analytics (Optional)
# ==================================
# Google Analytics 4 Tracking ID (format: G-XXXXXXXXXX)
# Get this from: https://analytics.google.com → Admin → Property Settings
# Leave blank to disable analytics
NEXT_PUBLIC_GA_ID=

# ==================================
# Google AdSense (Optional)
# ==================================
# Your AdSense Publisher ID (format: ca-pub-xxxxxxxxxxxxxxxx)
# Get this from: https://adsense.google.com
# Leave blank to disable AdSense ads
NEXT_PUBLIC_ADSENSE_ID=

# ==================================
NEXT_PUBLIC_COFOUNDER_AGENT_URL=http://localhost:8000

# ==================================
# External Services
# ==================================
SERPER_API_KEY=your-serper-api-key-here
NEWSLETTER_API_KEY=your-newsletter-api-key-here

# ==================================
# Feature Flags
# ==================================
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true

# ==================================
# Logging & Monitoring (Sentry)
# ==================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ==================================
# Giscus Comments (GitHub Discussions)
# ==================================
# Get these from: https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
