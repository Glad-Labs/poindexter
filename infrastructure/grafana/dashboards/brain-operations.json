        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "rawSql": "SELECT time, SUM(cnt) OVER (ORDER BY time) as cumulative_embeddings FROM (SELECT date_trunc('day', created_at) as time, COUNT(*) as cnt FROM embeddings WHERE $__timeFilter(created_at) GROUP BY 1) sub ORDER BY time",
