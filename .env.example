# ==========================================================================
# Poindexter — Environment Configuration (FALLBACK ONLY)
# ==========================================================================
#
# Preferred setup path (no .env needed):
#
#     poindexter setup
#
# ...writes ~/.poindexter/bootstrap.toml with the ONE value required to
# reach the database. Everything else (200+ keys) lives in the app_settings
# table and can be changed at runtime without a redeploy.
#
# Use this .env file only when bootstrap.toml isn't practical:
#   - Docker / CI contexts
#   - Legacy deployments that predate bootstrap.toml (#198)
#   - Temporarily overriding a DB-backed setting for debugging
#
# Any real value here is a secret leak waiting to happen — never commit.
# See docs/operations/environment-variables.md for the canonical list.
# ==========================================================================


# -------- Required (fail-loud if missing) --------
# Bearer token for the worker's REST API. Generate: openssl rand -base64 32
API_TOKEN=change-me-in-production

# Self-hosted Postgres stack (docker-compose.local.yml). Generate each:
# openssl rand -hex 32
LOCAL_POSTGRES_PASSWORD=
GRAFANA_PASSWORD=
PGADMIN_PASSWORD=


# -------- Database (bootstrap-only; prefer bootstrap.toml) --------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Resolution order: --db-url arg → bootstrap.toml → DATABASE_URL → LOCAL_DATABASE_URL
DATABASE_URL=


# -------- Optional (sensible defaults — only set to override) --------
# API_BASE_URL=http://localhost:8002
# PORT=8002
# ENVIRONMENT=production
# DEVELOPMENT_MODE=false                        # never true in prod
# DEPLOYMENT_MODE=worker                        # "worker" | "coordinator"
# SITE_NAME=Glad Labs
# SITE_DOMAIN=gladlabs.io
# SITE_URL=https://www.gladlabs.io
# COMPANY_NAME=Glad Labs

# Ollama — BOTH must be set to the same URL (MemoryClient reads OLLAMA_URL,
# OllamaClient reads OLLAMA_BASE_URL).
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_URL=http://host.docker.internal:11434
# DEFAULT_OLLAMA_MODEL=auto

# LOCAL_POSTGRES_USER=poindexter
# LOCAL_POSTGRES_DB=poindexter_brain
# GRAFANA_USER=admin


# -------- Optional integrations (feature off unless set) --------
# PEXELS_API_KEY=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# OPENCLAW_GATEWAY_URL=
# OPENCLAW_GATEWAY_TOKEN=


# -------- Observability (Sentry) --------
# SENTRY_DSN=
# ENABLE_TRACING=false


# -------- Public site (Next.js — separate from backend) --------
# These are duplicated in web/public-site/.env.example for the Next.js build.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8002
# REVALIDATE_SECRET=                            # openssl rand -base64 32


# ==========================================================================
# Everything else — model thresholds, prompt templates, cost guards, QA
# weights, auto-publish rules, anomaly windows, storage provider keys,
# cloud LLM API keys, Discord / Strapi / Giscus / AdSense / GA settings —
# lives in the app_settings table. Set via the settings API:
#
#   curl -X PUT http://localhost:8002/api/settings/<key> \
#     -H "Authorization: Bearer $API_TOKEN" \
#     -d '{"value": "..."}'
#
# Or via SQL against the app_settings table. No redeploy required.
# ==========================================================================
