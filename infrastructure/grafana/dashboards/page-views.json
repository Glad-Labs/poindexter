            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(c.name,'none') as cat, COUNT(p.id) as posts, SUM(COALESCE(p.view_count,0)) as views FROM posts p LEFT JOIN categories c ON p.category_id=c.id WHERE p.status='published' GROUP BY 1 ORDER BY 3 DESC",
          "refId": "A"
        }
      ]
