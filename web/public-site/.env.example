# ==================================
# Glad Labs Public Site - Environment Configuration
# ==================================
# Development: Copy this file to .env.local and fill in your values
# Production: Secrets come from Vercel environment variables
# Never commit real secrets to version control!

# === FastAPI Backend (REQUIRED) ===
# Points to the running FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# === Site URL (REQUIRED) ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Glad Labs

# === Sentry Error Tracking (Optional) ===
# Leave blank to disable
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# === Google Analytics (Optional) ===
# Google Analytics 4 Tracking ID (format: G-XXXXXXXXXX)
# https://analytics.google.com
NEXT_PUBLIC_GA_ID=

# === Google AdSense (Optional) ===
# Publisher ID (format: ca-pub-xxxxxxxxxxxxxxxx)
# https://adsense.google.com
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_ADSENSE_SLOT_ID=

# === Giscus Comments (Optional) ===
# GitHub Discussions-based comments — https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# === Feature Flags ===
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SEARCH=true
