        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "local-brain-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH expanded AS (\n  SELECT al.timestamp,\n         (al.details->>'approved')::boolean AS pass_approved,\n         r.value->>'reviewer' AS reviewer,\n         r.value->>'provider' AS provider,\n         (r.value->>'approved')::boolean AS reviewer_approved,\n         (r.value->>'score')::float AS reviewer_score,\n         (r.value->>'advisory')::boolean AS advisory\n  FROM audit_log al\n  CROSS JOIN LATERAL jsonb_array_elements(al.details->'reviews') AS r(value)\n  WHERE al.event_type = 'qa_pass_completed'\n    AND al.timestamp > NOW() - INTERVAL '24 hours'\n)\nSELECT reviewer AS \"Reviewer\",\n       provider AS \"Provider\",\n       COUNT(*)::int AS \"Runs\",\n       AVG(CASE WHEN reviewer_approved THEN 1.0 ELSE 0.0 END)::float AS \"Approval Rate\",\n       ROUND(AVG(reviewer_score)::numeric, 1) AS \"Avg Score\",\n       SUM(CASE WHEN advisory THEN 1 ELSE 0 END)::int AS \"Advisory Calls\",\n       SUM(CASE WHEN NOT advisory AND NOT reviewer_approved THEN 1 ELSE 0 END)::int AS \"Hard Vetoes\"\nFROM expanded\nGROUP BY reviewer, provider\nORDER BY \"Runs\" DESC;",
          "refId": "A"
        }
      ],
      "title": "Per-Reviewer Stats (24h)",
      "type": "table"
    },
