    {
      "type": "stat",
      "title": "Scrape targets up/down",
      "datasource": {
        "type": "prometheus",
        "uid": "local-prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}} @ {{instance}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "orange"
                },
                "1": {
                  "text": "UP",
                  "color": "blue"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "orange"
              },
              {
                "value": 1,
                "color": "blue"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "stat",
