FROM python:3.12-slim

WORKDIR /app

# Install system deps.
# chromium runtime libs are here because the preview-screenshot QA
# reviewer launches Playwright's bundled chromium from inside the
# container. They're a few hundred MB but cold bytes when the feature
# is off (qa_preview_screenshot_enabled=false by default).
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl postgresql-client \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libatspi2.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libx11-6 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Install poetry
RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir poetry

# Install dependencies first as a cache layer — pyproject.toml + poetry.lock
# only. The actual project ("poindexter-backend") is installed in a later
# step AFTER application code is copied, because installing the project
# creates dist-info entry_points which the plugin registry consults at
# runtime (gh#152). Pulling that into the same layer as the source means
# every code change re-resolves dependencies; splitting keeps the
# heavy dep-resolution layer cached.
COPY pyproject.toml poetry.lock ./
RUN poetry config virtualenvs.create false && \
    poetry install --no-root --no-dev --no-interaction 2>/dev/null || \
    poetry install --no-root --no-interaction

# Install Playwright's bundled chromium to a shared location so the
# runtime user (if different from the build user) can find it.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright
RUN python -m playwright install chromium && \
    chmod -R a+rX /opt/ms-playwright

# Copy application code
COPY . .

# Now install the project itself so its [tool.poetry.plugins."poindexter.*"]
# entry_points land in dist-info. WITHOUT this step, the runtime's
# importlib.metadata.entry_points(group="poindexter.jobs") returns
# empty and PluginScheduler quietly skips every job declared only in
# pyproject.toml — caught and fixed in commit 5e421c6d, properly
# resolved here per gh#152.
#
# Layout note: pyproject.toml's `packages = [{include="cofounder_agent",
# from=".."}]` expects the package to live at <pyproject_dir>/../cofounder_agent.
# In the host that's src/cofounder_agent/ (relative to src/cofounder_agent/
# the pyproject.toml lives in). In the container with WORKDIR=/app and
# `COPY . .`, the package files land directly in /app/, so /app/.. = /
# wouldn't have cofounder_agent. Symlink /cofounder_agent -> /app/ so
# the wheel builder can resolve the include without changing pyproject.toml
# (which would break the host's local poetry install).
RUN ln -s /app /cofounder_agent && \
    pip install --no-deps --no-cache-dir . && \
    rm /cofounder_agent

# Runtime layout fixup. The wheel built above ships entry_points whose
# targets are ``cofounder_agent.services.jobs.X`` (matches pyproject.toml's
# ``packages`` config), but the container runs with WORKDIR=/app where
# Python imports are flat — ``services.jobs.X`` works, but
# ``cofounder_agent.services.jobs.X`` doesn't unless something on sys.path
# exposes a ``cofounder_agent`` package whose contents are /app/.
#
# Symlinking /app under site-packages/ makes ``import cofounder_agent.<x>``
# resolve to ``/app/<x>``. Same files, two import names — the existing
# flat-import code paths keep working AND the dist-info entry_points
# resolve cleanly.
RUN ln -s /app /usr/local/lib/python3.12/site-packages/cofounder_agent

# Non-root user. chmod 0711 on /root so appuser can *traverse* it to reach
# SDXL-generated images under /root/.poindexter/generated-images/ (via the
# compose volume mount) — the directory's own 0777 perms let appuser read
# files; only /root itself blocked traversal until now. Without this,
# featured-image generation silently fell back to Pexels because
# os.path.exists() on the SDXL-returned path raised PermissionError.
RUN addgroup --system --gid 1001 appgroup && \
    adduser --system --uid 1001 --ingroup appgroup --home /home/appuser appuser && \
    chown -R appuser:appgroup /app && \
    chmod 0711 /root
USER appuser

# Health check endpoint
HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8002/api/health')" || exit 1

EXPOSE 8002

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8002"]
