          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT cl.model, COUNT(*) as tasks, ROUND(AVG(ct.quality_score)::numeric,1) as avg_q, MIN(ct.quality_score) as min_q, MAX(ct.quality_score) as max_q FROM cost_logs cl JOIN content_tasks ct ON cl.task_id=ct.task_id::text WHERE ct.quality_score IS NOT NULL GROUP BY 1 ORDER BY 3 DESC",
          "refId": "A"
        }
      ]
